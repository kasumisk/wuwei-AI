// ============================================================
// Wuwei-AI V3 — 智能饮食推荐系统 Prisma Schema
// 五层架构: Data → Feature → Scoring → Recommendation → Learning
// ============================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ============================================================
// 1. 用户系统
// ============================================================

enum AuthType {
  EMAIL
  PHONE
  GOOGLE
  WECHAT
  APPLE
  ANONYMOUS
}

enum GoalType {
  FAT_LOSS
  MUSCLE_GAIN
  HEALTH
  HABIT
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model AppUser {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authType      AuthType   @default(EMAIL)
  email         String?    @unique
  phone         String?    @unique
  googleId      String?    @unique @map("google_id")
  wechatOpenId  String?    @unique @map("wechat_open_id")
  appleId       String?    @unique @map("apple_id")
  passwordHash  String?    @map("password_hash")
  displayName   String?    @map("display_name")
  avatarUrl     String?    @map("avatar_url")
  status        UserStatus @default(ACTIVE)
  region        String     @default("CN") @db.VarChar(5)
  locale        String     @default("zh") @db.VarChar(10)
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  profile           UserProfile?
  behaviorProfile   UserBehaviorProfile?
  preferences       UserFoodPreference?
  foodRecords       FoodRecord[]
  dailySummaries    DailySummary[]
  dailyPlans        DailyPlan[]
  feedbacks         RecommendationFeedback[]
  explorationStates FoodExplorationState[]
  achievements      UserAchievement[]
  challenges        UserChallenge[]
  coachConversations CoachConversation[]

  @@map("app_users")
}

model UserProfile {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @unique @map("user_id") @db.Uuid
  gender          Gender?
  birthYear       Int?          @map("birth_year")
  heightCm        Float?        @map("height_cm")
  weightKg        Float?        @map("weight_kg")
  targetWeightKg  Float?        @map("target_weight_kg")
  activityLevel   ActivityLevel @default(MODERATE) @map("activity_level")
  goalType        GoalType      @default(HEALTH) @map("goal_type")
  dailyCalories   Int?          @map("daily_calories")
  carbsRatio      Float         @default(0.50) @map("carbs_ratio")
  proteinRatio    Float         @default(0.20) @map("protein_ratio")
  fatRatio        Float         @default(0.30) @map("fat_ratio")
  dietaryRestrictions String[]  @default([]) @map("dietary_restrictions")
  allergens       String[]      @default([])
  diabetesFriendly Boolean      @default(false) @map("diabetes_friendly")
  coachStyle      String        @default("friendly") @map("coach_style") @db.VarChar(20)
  discipline      Float         @default(0.5) @db.DoublePrecision

  user            AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("user_profiles")
}

// ============================================================
// 2. 用户行为画像 (L5 学习层数据)
// ============================================================

model UserBehaviorProfile {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  streakDays          Int      @default(0) @map("streak_days")
  avgComplianceRate   Float    @default(0.5) @map("avg_compliance_rate") @db.DoublePrecision
  avgProteinRatio7d   Float    @default(0.15) @map("avg_protein_ratio_7d") @db.DoublePrecision
  avgProcessingLevel7d Float   @default(2.0) @map("avg_processing_level_7d") @db.DoublePrecision
  avgGI7d             Float    @default(50.0) @map("avg_gi_7d") @db.DoublePrecision
  weightPlateau       Int      @default(0) @map("weight_plateau")
  bingeRiskHours      Int[]    @default([]) @map("binge_risk_hours")
  failureTriggers     String[] @default([]) @map("failure_triggers")
  derivedTags         String[] @default([]) @map("derived_tags")
  breakfastRegularity Float    @default(0.5) @map("breakfast_regularity") @db.DoublePrecision
  lunchRegularity     Float    @default(0.5) @map("lunch_regularity") @db.DoublePrecision
  dinnerRegularity    Float    @default(0.5) @map("dinner_regularity") @db.DoublePrecision

  user                AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("user_behavior_profiles")
}

// ============================================================
// 3. 用户食物偏好 (L2 特征层)
// ============================================================

model UserFoodPreference {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  categoryPrefs     Json     @default("{}") @map("category_prefs")
  foodGroupPrefs    Json     @default("{}") @map("food_group_prefs")
  tagPrefs          Json     @default("{}") @map("tag_prefs")
  lovedFoodIds      String[] @default([]) @map("loved_food_ids")
  avoidedFoodIds    String[] @default([]) @map("avoided_food_ids")
  mealPatterns      Json     @default("{}") @map("meal_patterns")

  user              AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_food_preferences")
}

// ============================================================
// 4. 食物系统 (L1 数据层)
// ============================================================

enum FoodStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FoodCategory {
  PROTEIN
  GRAIN
  VEGGIE
  FRUIT
  DAIRY
  FAT
  BEVERAGE
  SNACK
  CONDIMENT
  COMPOSITE
}

enum FoodSourceType {
  OFFICIAL
  ESTIMATED
  AI
  COMMUNITY
}

model Food {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String       @unique @db.VarChar(30)
  name              String       @db.VarChar(200)
  category          FoodCategory
  subCategory       String?      @map("sub_category") @db.VarChar(50)
  foodGroup         String?      @map("food_group") @db.VarChar(50)
  mainIngredient    String?      @map("main_ingredient") @db.VarChar(100)
  barcode           String?      @db.VarChar(50)
  status            FoodStatus   @default(DRAFT)

  // 营养数据 (per 100g)
  caloriesPer100g   Float        @map("calories_per_100g") @db.DoublePrecision
  proteinPer100g    Float        @default(0) @map("protein_per_100g") @db.DoublePrecision
  fatPer100g        Float        @default(0) @map("fat_per_100g") @db.DoublePrecision
  carbsPer100g      Float        @default(0) @map("carbs_per_100g") @db.DoublePrecision
  fiberPer100g      Float        @default(0) @map("fiber_per_100g") @db.DoublePrecision
  sugarPer100g      Float        @default(0) @map("sugar_per_100g") @db.DoublePrecision
  sodiumPer100g     Float        @default(0) @map("sodium_per_100g") @db.DoublePrecision
  saturatedFatPer100g Float      @default(0) @map("saturated_fat_per_100g") @db.DoublePrecision
  transFatPer100g   Float        @default(0) @map("trans_fat_per_100g") @db.DoublePrecision

  // 微量营养素 (per 100g)
  potassium         Float?       @db.DoublePrecision
  calcium           Float?       @db.DoublePrecision
  iron              Float?       @db.DoublePrecision
  vitaminA          Float?       @map("vitamin_a") @db.DoublePrecision
  vitaminC          Float?       @map("vitamin_c") @db.DoublePrecision
  vitaminD          Float?       @map("vitamin_d") @db.DoublePrecision
  vitaminE          Float?       @map("vitamin_e") @db.DoublePrecision
  vitaminB12        Float?       @map("vitamin_b12") @db.DoublePrecision
  folate            Float?       @db.DoublePrecision
  zinc              Float?       @db.DoublePrecision
  magnesium         Float?       @db.DoublePrecision
  omega3            Float?       @db.DoublePrecision
  omega6            Float?       @db.DoublePrecision

  // 健康指标
  glycemicIndex     Int?         @map("glycemic_index")
  glycemicLoad      Float?       @map("glycemic_load") @db.DoublePrecision
  processingLevel   Int          @default(1) @map("processing_level")
  qualityScore      Float        @default(5.0) @map("quality_score") @db.DoublePrecision
  satietyScore      Float        @default(5.0) @map("satiety_score") @db.DoublePrecision
  antiInflammatory  Boolean      @default(false) @map("anti_inflammatory")

  // 份量
  standardServingG  Float        @default(100) @map("standard_serving_g") @db.DoublePrecision
  servingUnit       String?      @map("serving_unit") @db.VarChar(50)

  // 分类/标签
  tags              String[]     @default([])
  mealTypes         String[]     @default([]) @map("meal_types")
  isProcessed       Boolean      @default(false) @map("is_processed")
  isFried           Boolean      @default(false) @map("is_fried")
  allergens         String[]     @default([])

  // 数据来源
  source            FoodSourceType @default(ESTIMATED)
  sourceId          String?      @map("source_id") @db.VarChar(50)
  confidence        Float        @default(0.5) @db.DoublePrecision
  searchWeight      Int          @default(0) @map("search_weight")

  // 推荐统计
  globalAcceptRate  Float        @default(0.5) @map("global_accept_rate") @db.DoublePrecision
  recommendCount    Int          @default(0) @map("recommend_count")

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  translations      FoodTranslation[]
  regionalInfo      FoodRegionalInfo[]
  changeLogs        FoodChangeLog[]
  explorationStates FoodExplorationState[]

  @@index([category, status])
  @@index([name])
  @@index([status])
  @@map("foods")
}

model FoodTranslation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  foodId          String   @map("food_id") @db.Uuid
  language        String   @db.VarChar(10)
  translatedName  String   @map("translated_name") @db.VarChar(200)
  description     String?

  food            Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([foodId, language])
  @@map("food_translations")
}

model FoodRegionalInfo {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  foodId          String   @map("food_id") @db.Uuid
  region          String   @db.VarChar(5)
  availability    String   @default("common") @db.VarChar(20)
  localPopularity Float    @default(0.5) @map("local_popularity") @db.DoublePrecision
  seasonality     String[] @default([])
  localName       String?  @map("local_name") @db.VarChar(200)

  food            Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, region])
  @@index([region])
  @@map("food_regional_info")
}

model FoodDataSource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  sourceType  String   @map("source_type") @db.VarChar(50)
  apiUrl      String?  @map("api_url")
  lastSyncAt  DateTime? @map("last_sync_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("food_sources")
}

model FoodChangeLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  foodId      String   @map("food_id") @db.Uuid
  action      String   @db.VarChar(20)
  changes     Json?
  changedBy   String?  @map("changed_by") @db.Uuid
  changedAt   DateTime @default(now()) @map("changed_at")

  food        Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([foodId])
  @@map("food_change_logs")
}

// ============================================================
// 5. 食物记录 & 每日数据
// ============================================================

model FoodRecord {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  mealType        String   @map("meal_type") @db.VarChar(20)
  imageUrl        String?  @map("image_url")
  source          String   @default("manual") @db.VarChar(20)
  recognizedText  String?  @map("recognized_text")
  foods           Json     @default("[]")
  totalCalories   Float    @default(0) @map("total_calories") @db.DoublePrecision
  totalProtein    Float    @default(0) @map("total_protein") @db.DoublePrecision
  totalFat        Float    @default(0) @map("total_fat") @db.DoublePrecision
  totalCarbs      Float    @default(0) @map("total_carbs") @db.DoublePrecision
  decision        String?  @db.VarChar(10)
  decisionScore   Float?   @map("decision_score") @db.DoublePrecision
  reasoning       String?
  mealDate        DateTime @default(now()) @map("meal_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")

  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mealDate])
  @@map("food_records")
}

model DailySummary {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  date            DateTime @db.Date
  totalCalories   Float    @default(0) @map("total_calories") @db.DoublePrecision
  calorieGoal     Float    @default(0) @map("calorie_goal") @db.DoublePrecision
  totalProtein    Float    @default(0) @map("total_protein") @db.DoublePrecision
  totalFat        Float    @default(0) @map("total_fat") @db.DoublePrecision
  totalCarbs      Float    @default(0) @map("total_carbs") @db.DoublePrecision
  nutritionScore  Float?   @map("nutrition_score") @db.DoublePrecision
  mealsLogged     Int      @default(0) @map("meals_logged")

  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_summaries")
}

// ============================================================
// 6. 推荐系统
// ============================================================

model DailyPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  date            DateTime @db.Date
  breakfastPlan   Json?    @map("breakfast_plan")
  lunchPlan       Json?    @map("lunch_plan")
  dinnerPlan      Json?    @map("dinner_plan")
  snackPlan       Json?    @map("snack_plan")
  totalCalories   Float    @default(0) @map("total_calories") @db.DoublePrecision
  totalProtein    Float    @default(0) @map("total_protein") @db.DoublePrecision
  totalFat        Float    @default(0) @map("total_fat") @db.DoublePrecision
  totalCarbs      Float    @default(0) @map("total_carbs") @db.DoublePrecision
  strategy        String?  @db.VarChar(200)
  adjustments     Json     @default("[]")
  calibrationLog  Json?    @map("calibration_log")
  version         Int      @default(1)

  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_plans")
}

// ============================================================
// 7. 反馈 & 探索
// ============================================================

enum FeedbackSignal {
  PLAN_ACCEPTED
  FOOD_COMPLETED
  FOOD_REPLACED
  FOOD_SKIPPED
  FOOD_FAVORITED
  MANUAL_RECORD
}

model RecommendationFeedback {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  foodId          String?        @map("food_id") @db.Uuid
  foodName        String         @map("food_name") @db.VarChar(200)
  signal          FeedbackSignal
  mealType        String         @map("meal_type") @db.VarChar(20)
  goalType        String?        @map("goal_type") @db.VarChar(20)
  recommendationScore Float?     @map("recommendation_score") @db.DoublePrecision
  replacedWithId  String?        @map("replaced_with_id") @db.Uuid
  context         Json?
  createdAt       DateTime       @default(now()) @map("created_at")

  user            AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([foodId])
  @@map("recommendation_feedbacks")
}

model FoodExplorationState {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  foodId            String   @map("food_id") @db.Uuid
  alpha             Float    @default(1) @db.DoublePrecision
  betaParam         Float    @default(1) @map("beta") @db.DoublePrecision
  lastRecommendedAt DateTime? @map("last_recommended_at")
  lastFeedbackAt    DateTime? @map("last_feedback_at")

  user              AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  food              Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId])
  @@index([userId])
  @@map("food_exploration_states")
}

// ============================================================
// 8. AI教练
// ============================================================

model CoachConversation {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  topic       String?        @db.VarChar(100)
  status      String         @default("active") @db.VarChar(20)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user        AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    CoachMessage[]

  @@index([userId])
  @@map("coach_conversations")
}

model CoachMessage {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId  String            @map("conversation_id") @db.Uuid
  role            String            @db.VarChar(20)
  content         String
  sentiment       String?           @db.VarChar(20)
  createdAt       DateTime          @default(now()) @map("created_at")

  conversation    CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("coach_messages")
}

// ============================================================
// 9. 游戏化
// ============================================================

model Achievement {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String            @unique @db.VarChar(50)
  title       String            @db.VarChar(100)
  description String?
  icon        String?           @db.VarChar(50)
  type        String            @db.VarChar(30)
  rules       Json
  points      Int               @default(10)
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")
  progress      Float       @default(0) @db.DoublePrecision

  user          AppUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Challenge {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String          @db.VarChar(100)
  description   String?
  durationDays  Int             @map("duration_days")
  rules         Json
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")

  participants  UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  challengeId     String    @map("challenge_id") @db.Uuid
  startDate       DateTime  @map("start_date") @db.Date
  progress        Json      @default("{}")
  completedAt     DateTime? @map("completed_at")

  user            AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge       Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

// ============================================================
// 10. AI决策日志
// ============================================================

model AiDecisionLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  decision    String   @db.VarChar(20)
  reasoning   String?
  inputData   Json?    @map("input_data")
  outputData  Json?    @map("output_data")
  modelUsed   String?  @map("model_used") @db.VarChar(50)
  latencyMs   Int?     @map("latency_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("ai_decision_logs")
}

// ============================================================
// 11. 管理员
// ============================================================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model AdminUser {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username    String    @unique @db.VarChar(50)
  email       String    @unique
  passwordHash String   @map("password_hash")
  displayName String?   @map("display_name") @db.VarChar(100)
  role        AdminRole @default(ADMIN)
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}
