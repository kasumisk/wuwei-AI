{
  "compilerOptions": {
    "module": "node16",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "paths": {
      "@/*": ["./src/*"],
      "@common/*": ["./src/common/*"],
      "@core/*": ["./src/core/*"],
      "@modules/*": ["./src/modules/*"],
      "@diet/*": ["./src/modules/diet/*"],
      "@diet-rec/*": ["./src/modules/diet/app/recommendation/*"],
      "@food/*": ["./src/modules/food/*"],
      "@user/*": ["./src/modules/user/*"],
      "@subscription/*": ["./src/modules/subscription/*"],
      "@auth/*": ["./src/modules/auth/*"],
      "@strategy/*": ["./src/modules/strategy/*"],
      "@gateway/*": ["./src/gateway/*"],
      "@storage/*": ["./src/storage/*"],
      "@food-pipeline/*": ["./src/food-pipeline/*"],
      "@scripts/*": ["./src/scripts/*"]
    }
  },
  "include": ["src/**/*", "test/v2.4-integration.spec.ts", "test/v2.4-integration.test.ts", "test/v2.6-integration.spec.ts", "test/v2.7-integration.spec.ts", "test/v2.8-integration.spec.ts", "test/v2.9-integration.spec.ts", "test/v3.0-integration.spec.ts", "test/v3.2-phase1.spec.ts"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
