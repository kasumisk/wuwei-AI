/// 策略调优历史 — 记录推荐策略自动或手动切换前后的效果对比，用于策略迭代评估
model StrategyTuningLog {
  /// 主键 UUID
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 调优针对的用户分群名称（如 fat_loss_active）
  segmentName      String    @map("segment_name") @db.VarChar(50)
  /// 切换前使用的策略名称
  previousStrategy String    @map("previous_strategy") @db.VarChar(50)
  /// 切换后使用的策略名称
  newStrategy      String    @map("new_strategy") @db.VarChar(50)
  /// 切换前的指标值（如采纳率）
  previousRate     Float     @map("previous_rate")
  /// 切换后的指标值（如采纳率）
  newRate          Float     @map("new_rate")
  /// 改善幅度（new_rate - previous_rate）
  improvement      Float
  /// 是否由系统自动应用（true=自动，false=人工触发）
  autoApplied      Boolean   @default(false) @map("auto_applied")
  /// V7.9: 审核状态 — auto_applied | pending_review | approved | rejected
  reviewStatus     String    @default("auto_applied") @map("review_status") @db.VarChar(20)
  /// V7.9: 审核人（Admin 用户 ID）
  reviewedBy       String?   @map("reviewed_by") @db.VarChar(100)
  /// V7.9: 审核时间
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(6)
  /// V7.9: 审核备注
  reviewNote       String?   @map("review_note") @db.Text
  /// 记录创建时间
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([segmentName], map: "idx_stl_segment")
  @@index([createdAt], map: "idx_stl_created")
  @@index([reviewStatus], map: "idx_stl_review_status")
  @@map("strategy_tuning_log")
}

/// 替换模式聚合 — 用户 A→B 替换行为的频率统计，用于推荐权重调整
model ReplacementPatterns {
  /// 主键 UUID
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  userId       String   @map("user_id") @db.Uuid
  /// 被替换的原食物 ID
  fromFoodId   String   @map("from_food_id") @db.Uuid
  /// 被替换的原食物名称（冗余存储）
  fromFoodName String   @map("from_food_name") @db.VarChar(200)
  /// 替换成的目标食物 ID
  toFoodId     String   @map("to_food_id") @db.Uuid
  /// 替换成的目标食物名称（冗余存储）
  toFoodName   String   @map("to_food_name") @db.VarChar(200)
  /// 该替换发生的总次数
  frequency    Int      @default(1)
  /// 最近一次发生替换的时间
  lastOccurred DateTime @default(now()) @map("last_occurred") @db.Timestamptz(6)
  /// V6.7 Phase 2-E: 替换发生的餐次类型（breakfast/lunch/dinner/snack）
  mealType     String?  @map("meal_type") @db.Text
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, fromFoodId, toFoodId], map: "uq_replacement_pattern")
  @@index([userId], map: "idx_rp_user")
  @@index([fromFoodId], map: "idx_rp_from_food")
  @@index([mealType], map: "idx_rp_meal_type")
  @@map("replacement_patterns")
}

/// V6.9 Phase 2-C: 推荐执行记录 — 追踪推荐→实际执行的闭环，计算执行率
model RecommendationExecutions {
  /// 主键 UUID
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  userId           String    @map("user_id") @db.Uuid
  /// 关联的推荐 ID（来源于推荐引擎的请求 ID，可选）
  recommendationId String?   @map("recommendation_id") @db.VarChar(255)
  /// 餐次类型：breakfast/lunch/dinner/snack
  mealType         String    @map("meal_type") @db.VarChar(20)
  recommendedFoods Json      @map("recommended_foods") /// 推荐的食物 ID 列表
  executedFoods    Json?     @map("executed_foods") /// 实际执行的食物 ID 列表（分析结果回填）
  executionRate    Float?    @map("execution_rate") /// 执行率 0-1（匹配的食物数/推荐的食物数）
  deviationNotes   Json?     @map("deviation_notes") /// 偏差记录（替换/增加/减少了什么）
  /// 推荐发出时间
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 用户实际执行（进餐）时间（异步回填）
  executedAt       DateTime? @map("executed_at") @db.Timestamptz(6)

  @@index([userId, createdAt], map: "idx_rec_exec_user_created")
  @@index([userId, mealType], map: "idx_rec_exec_user_meal")
  @@map("recommendation_executions")
}

/// V6.5 Phase 3J: 暴食干预效果追踪 — 记录每次暴食干预事件及后续行为变化，用于评估干预有效性
model BingeInterventionLogs {
  /// 主键 UUID
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  userId        String    @map("user_id") @db.Uuid
  /// 干预触发时段（24h 制）
  triggerHour   Int       @map("trigger_hour") @db.SmallInt
  /// 干预消息内容
  message       String    @db.VarChar(500)
  /// 干预前 2h 卡路里摄入
  preCalories   Float?    @map("pre_calories")
  /// 干预后 3h 卡路里摄入（异步回填）
  postCalories  Float?    @map("post_calories")
  /// 干预是否有效：post_calories < pre_expected 视为有效（异步回填）
  effective     Boolean?
  /// 用户是否在干预后 3h 内新增了食物记录
  hadPostRecord Boolean?  @map("had_post_record")
  /// 异步评估时间
  evaluatedAt   DateTime? @map("evaluated_at") @db.Timestamptz(6)
  /// 记录创建时间
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt], map: "idx_bil_user_created")
  @@index([effective], map: "idx_bil_effective")
  @@map("binge_intervention_logs")
}

/// V7.0: 目标阶段表 — 存储 CompoundGoal 中各个阶段的配置与执行状态
model GoalPhases {
  /// 主键 UUID
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  userId             String    @map("user_id") @db.Uuid
  goalType           String    @map("goal_type") @db.VarChar(50) /// GoalType: fat_loss/muscle_gain/health/habit
  name               String    @db.VarChar(100) /// 阶段名称（用户可见）
  durationWeeks      Int       @map("duration_weeks") /// 阶段持续周数
  calorieMultiplier  Float     @default(1.0) @map("calorie_multiplier") /// 相对 TDEE 的热量调整比例
  macroRatioOverride Json?     @map("macro_ratio_override") @db.JsonB /// { carb: [min, max], fat: [min, max] }
  phaseOrder         Int       @map("phase_order") /// 阶段顺序（0-based）
  isActive           Boolean   @default(false) @map("is_active") /// 当前是否激活
  startedAt          DateTime? @map("started_at") @db.Timestamptz(6) /// 阶段开始时间
  completedAt        DateTime? @map("completed_at") @db.Timestamptz(6) /// 阶段完成时间
  /// 创建时间
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([userId, isActive], map: "idx_goal_phases_user_active")
  @@index([userId, phaseOrder], map: "idx_goal_phases_user_order")
  @@map("goal_phases")
}

// ═══════════════════════════════════════════════════════════════════════════
// V8.2 Food Infrastructure Refactor — 拆表关联模型
// ═══════════════════════════════════════════════════════════════════════════

/// 食物语义向量表（多模型共存：legacy_v4 / openai_v5 / 未来新模型）
/// 拆出原因：embedding 字段宽（1536 维 + Float[] 双份）、热路径 food-pool-cache 不读
model FoodEmbedding {
  /// 主键 UUID
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联食物 ID
  foodId       String                 @map("food_id") @db.Uuid
  /// 模型名（legacy_v4 / openai_v5 / ...）
  modelName    String                 @map("model_name") @db.VarChar(50)
  /// 模型版本（如 text-embedding-3-small）
  modelVersion String?                @map("model_version") @db.VarChar(100)
  /// pgvector 类型向量（v5+ 使用此列）
  vector       Unsupported("vector")?
  /// 旧版 Float[] 向量（legacy_v4 使用此列）
  vectorLegacy Float[]                @map("vector_legacy") @db.Real
  /// 向量维度
  dimension    Int
  /// 生成时间
  generatedAt  DateTime               @default(now()) @map("generated_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt    DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)

  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, modelName], map: "uq_food_embeddings_food_model")
  @@index([foodId], map: "idx_food_embeddings_food")
  @@index([modelName], map: "idx_food_embeddings_model")
  @@map("food_embeddings")
}

/// 字段级数据溯源表（成功/失败/置信度）
/// 拆出原因：原 failed_fields jsonb 不可索引；field_sources 可双层共存（主表保留 jsonb 缓存）
model FoodFieldProvenance {
  /// 主键 UUID
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联食物 ID
  foodId        String   @map("food_id") @db.Uuid
  /// 字段名（如 protein, calories）
  fieldName     String   @map("field_name") @db.VarChar(100)
  /// 数据来源（usda / cfsb / gpt / manual / translated / enrichment / ...）
  source        String   @db.VarChar(50)
  /// 置信度 0-1
  confidence    Float?
  /// 状态：success / failed / pending
  status        String   @default("success") @db.VarChar(20)
  /// 失败原因（status='failed' 时填写）
  failureReason String?  @map("failure_reason") @db.VarChar(500)
  /// 原始值快照（可选）
  rawValue      Json?    @map("raw_value")
  /// 创建时间
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, fieldName, source], map: "uq_food_field_provenance_food_field_source")
  @@index([foodId], map: "idx_food_field_provenance_food")
  @@index([fieldName], map: "idx_food_field_provenance_field")
  @@index([status], map: "idx_food_field_provenance_status")
  @@map("food_field_provenance")
}
