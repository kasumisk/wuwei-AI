generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider  = "postgresql"
  // 运行时连接（Neon 上请使用 PgBouncer pooled URL，需带 ?pgbouncer=true&connection_limit=1）
  url       = env("DATABASE_URL")
  // 仅 prisma migrate / introspect 使用（必须为 Neon direct/non-pooled URL）
  // 本地开发可与 DATABASE_URL 相同；Cloud Run 部署须分别配置
  directUrl = env("DIRECT_URL")
}

/// A/B 实验配置表 — 管理推荐引擎、UI 等各类 A/B 测试实验
model AbExperiments {
  /// 主键 UUID
  id          String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 实验名称（如 "推荐算法 v2 vs v1"）
  name        String                     @db.VarChar(100)
  /// 实验描述
  description String?
  /// 实验目标类型（"*" 表示通用；也可指定特定目标如 "fat_loss"）
  goalType    String                     @default("*") @map("goal_type") @db.VarChar(30)
  /// 实验状态：draft=草稿, running=运行中, paused=暂停, completed=已完成
  status      ab_experiments_status_enum @default(draft)
  /// 实验分组配置（JSON 数组，每组含 id/name/weight/config 等）
  groups      Json                       @default("[]")
  /// 实验开始时间
  startDate   DateTime?                  @map("start_date") @db.Timestamptz(6)
  /// 实验结束时间
  endDate     DateTime?                  @map("end_date") @db.Timestamptz(6)
  /// 创建时间
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt   DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "IDX_ab_experiments_status")
  @@map("ab_experiments")
}

/// 成就/徽章定义表 — 存储可解锁的成就配置（连续打卡、营养达标等）
model Achievements {
  /// 主键 UUID
  id          String  @id(map: "PK_1bc19c37c6249f70186f318d71d") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 成就唯一编码（如 "STREAK_7"、"CALORIE_100"）
  code        String  @unique(map: "UQ_cd74882f69ff37d7330e89c63d5") @db.VarChar(50)
  /// 成就展示名称
  name        String  @db.VarChar(100)
  /// 成就描述
  description String?
  /// 成就图标（emoji 或图标代码，最多 10 字符）
  icon        String? @db.VarChar(10)
  /// 成就分类（如 streak/nutrition/weight/social）
  category    String? @db.VarChar(30)
  /// 达成门槛值（如连续打卡 7 天则为 7）
  threshold   Int
  /// 奖励类型（如 points/badge/feature_unlock）
  rewardType  String? @map("reward_type") @db.VarChar(30)
  /// 奖励数值（如积分数量，默认 0）
  rewardValue Int     @default(0) @map("reward_value")

  @@map("achievements")
}

/// 后台管理员账号表 — 存储运营/技术人员的登录凭证和权限角色
model AdminUsers {
  /// 主键 UUID
  id          String                  @id(map: "PK_06744d221bb6145dc61e5dc441d") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 登录用户名，全局唯一
  username    String                  @unique(map: "IDX_2873882c38e8c07d98cb64f962") @db.VarChar(100)
  /// 登录密码（bcrypt 哈希）
  password    String                  @db.VarChar(255)
  /// 管理员邮箱，全局唯一
  email       String?                 @unique(map: "IDX_dcd0c8a4b10af9c986e510b9ec") @db.VarChar(255)
  /// 手机号
  phone       String?                 @db.VarChar(20)
  /// 角色：super_admin=超级管理员, admin=普通管理员
  role        admin_users_role_enum   @default(admin)
  /// 账号状态：active=正常, inactive=停用, suspended=封禁
  status      admin_users_status_enum @default(active)
  /// 头像 URL
  avatar      String?                 @db.VarChar(255)
  /// 显示昵称
  nickname    String?                 @db.VarChar(100)
  /// 最后登录时间
  lastLoginAt DateTime?               @map("last_login_at") @db.Timestamptz(6)
  /// 创建时间
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt   DateTime                @default(now()) @map("updated_at") @db.Timestamptz(6)
  userRoles   UserRoles[]

  @@map("admin_users")
}

/// AI 决策日志表 — 记录每次 AI 对食物记录的决策结果及用户反馈，用于模型效果评估
model AiDecisionLogs {
  /// 主键 UUID
  id            String   @id(map: "PK_e5aa864516bc349d6e085024cee") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的用户 ID
  userId        String   @map("user_id") @db.Uuid
  /// 关联的食物记录 ID（可为空，如纯咨询场景）
  recordId      String?  @map("record_id") @db.Uuid
  /// AI 决策时的输入上下文（JSON，含用户画像快照、食物信息等）
  inputContext  Json?    @map("input_context")
  /// 输入图片 URL（图片识别场景）
  inputImageUrl String?  @map("input_image_url")
  /// AI 决策结论：SAFE=安全可食/WARN=警告/STOP=建议停止
  decision      String?  @db.VarChar(10)
  /// 风险等级：low/mid/high
  riskLevel     String?  @map("risk_level") @db.VarChar(5)
  /// AI 完整响应（原始 JSON，含推理链路）
  fullResponse  Json?    @map("full_response")
  /// 用户是否遵从了 AI 建议
  userFollowed  Boolean? @map("user_followed")
  /// 用户对 AI 决策的主观反馈（helpful/not_helpful/wrong 等）
  userFeedback  String?  @map("user_feedback") @db.VarChar(20)
  /// 实际结果（用于后验分析，如 blood_sugar_ok/overeat 等）
  actualOutcome String?  @map("actual_outcome") @db.VarChar(20)
  /// 创建时间
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "idx_ai_logs_user")
  @@map("ai_decision_logs")
}

/// 分析记录与食物库的关联表 — 将一次识别分析中的每种食物与正式食物库或候选库关联
model AnalysisFoodLink {
  /// 主键 UUID
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的食物分析记录 ID
  analysisId          String              @map("analysis_id") @db.Uuid
  /// 匹配到的正式食物库 ID（精确匹配时填写）
  foodLibraryId       String?             @map("food_library_id") @db.Uuid
  /// 匹配到的候选食物 ID（模糊/新食物时填写）
  foodCandidateId     String?             @map("food_candidate_id") @db.Uuid
  /// 识别出的食物名称（原始文本）
  foodName            String              @map("food_name") @db.VarChar(120)
  /// 匹配类型：exact=精确匹配, fuzzy=模糊匹配, candidate=候选新食物, unknown=未知
  matchType           String              @map("match_type") @db.VarChar(20)
  /// 匹配置信度 0.00-100.00（百分比，小数点 2 位）
  confidence          Decimal?            @default(0) @db.Decimal(5, 2)
  /// 创建时间
  createdAt           DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  foodAnalysisRecords FoodAnalysisRecords @relation(fields: [analysisId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_afl_analysis")
  foodCandidate       FoodCandidate?      @relation(fields: [foodCandidateId], references: [id], onUpdate: NoAction, map: "fk_afl_food_candidate")
  foods               Food?               @relation(fields: [foodLibraryId], references: [id], onUpdate: NoAction, map: "fk_afl_food_library")

  @@index([analysisId], map: "idx_analysis_food_link_analysis_id")
  @@index([foodCandidateId], map: "idx_analysis_food_link_food_candidate_id")
  @@index([foodLibraryId], map: "idx_analysis_food_link_food_library_id")
  @@map("analysis_food_link")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// App 终端用户账号表 — 存储用户的认证信息、账号状态及各第三方登录标识
model AppUsers {
  /// 主键 UUID
  id                  String                   @id(map: "PK_9b97e4fbff9c2f3918fda27f999") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 登录方式：anonymous=匿名, google=谷歌, email=邮箱, phone=手机号, wechat=微信公众号, wechat_mini=微信小程序, apple=苹果
  authType            app_users_auth_type_enum @default(anonymous) @map("auth_type")
  /// 用户邮箱，全局唯一
  email               String?                  @unique(map: "IDX_28d5834968612821f4675a9f7a") @db.VarChar(255)
  /// 邮箱登录密码（bcrypt 哈希）
  password            String?                  @db.VarChar(255)
  /// Google OAuth 用户唯一 ID
  googleId            String?                  @unique(map: "IDX_77751cf159acfefb704456e4f6") @map("google_id") @db.VarChar(255)
  /// 设备唯一标识（匿名用户主键）
  deviceId            String?                  @map("device_id") @db.VarChar(255)
  /// 手机号，全局唯一（国际格式，如 +8613812345678）
  phone               String?                  @unique(map: "IDX_app_users_phone") @db.VarChar(20)
  /// 手机号是否已验证
  phoneVerified       Boolean                  @default(false) @map("phone_verified")
  /// 微信公众号 OpenID，全局唯一
  wechatOpenId        String?                  @unique(map: "IDX_45e81ae90b9a0d7fb2b72e21b2") @map("wechat_open_id") @db.VarChar(128)
  /// 微信 UnionID（同一微信主体下跨应用统一标识）
  wechatUnionId       String?                  @map("wechat_union_id") @db.VarChar(128)
  /// 微信小程序 OpenID，全局唯一
  wechatMiniOpenId    String?                  @unique(map: "IDX_app_users_wechat_mini_open_id") @map("wechat_mini_open_id") @db.VarChar(128)
  /// Apple Sign In 用户唯一 ID
  appleId             String?                  @unique(map: "IDX_458012dc4bdbf3309edd3205da") @map("apple_id") @db.VarChar(255)
  /// 用户昵称（来自第三方授权或自填）
  nickname            String?                  @db.VarChar(100)
  /// 头像 URL
  avatar              String?                  @db.VarChar(255)
  /// 账号状态：active=正常, inactive=未激活, banned=封禁
  status              app_users_status_enum    @default(active)
  /// 邮箱是否已验证
  emailVerified       Boolean                  @default(false) @map("email_verified")
  /// 最后登录时间
  lastLoginAt         DateTime?                @map("last_login_at") @db.Timestamptz(6)
  /// 扩展元数据（JSON，存放三方 OAuth 原始信息等）
  metadata            Json?
  /// 创建时间
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt           DateTime                 @default(now()) @map("updated_at") @db.Timestamptz(6)
  coachConversations  CoachConversations[]
  dailySummaries      DailySummaries[]
  foodRecords         FoodRecords[]
  profileSnapshots    ProfileSnapshots[]
  /// ARB-2026-04: userInferredProfiles merged into UserProfiles.inferredData
  userProfiles        UserProfiles?
  /// V6.5 Phase 2I: FK 补齐 — 反向关联
  dailyPlans          DailyPlans[]
  /// ARB-2026-04: userBehaviorProfiles merged into UserProfiles.behaviorData
  strategyAssignments StrategyAssignment[]
  notifications       Notification[]
  weightHistories     WeightHistory[]

  @@index([deviceId], map: "IDX_601d4f4be742d3ca28891c0207")
  @@map("app_users")
}

/// App 版本安装包表 — 存储每个版本对应的各平台、各渠道安装包信息
model AppVersionPackages {
  /// 主键 UUID
  id          String                             @id(map: "PK_cf82df0345378efd08dd5683389") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的版本 ID（外键 → app_versions.id）
  versionId   String                             @db.Uuid
  /// 平台：android / ios
  platform    app_version_packages_platform_enum
  /// 发布渠道（如 "official"、"huawei"、"appstore"、"gray"）
  channel     String                             @db.VarChar(50)
  /// 安装包下载地址
  downloadUrl String                             @db.VarChar(1000)
  /// 安装包文件大小，单位 Bytes
  fileSize    BigInt                             @default(0)
  /// 文件完整性校验码（如 SHA256）
  checksum    String?                            @db.VarChar(255)
  /// 是否启用此安装包
  enabled     Boolean                            @default(true)
  /// 创建时间
  createdAt   DateTime                           @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt   DateTime                           @default(now()) @db.Timestamptz(6)
  appVersions AppVersions                        @relation(fields: [versionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_ecb85e41b68428adb8df8fc0a01")

  @@unique([versionId, channel, platform], map: "IDX_app_version_packages_version_channel_platform")
  @@index([versionId], map: "IDX_app_version_packages_versionId")
  @@map("app_version_packages")
}

/// App 版本信息表 — 管理 iOS/Android 各版本的发布状态、灰度策略和更新类型
model AppVersions {
  /// 主键 UUID
  id                    String                       @id(map: "PK_8d36b0dcf0c026c7aad923c80fd") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 目标平台：android / ios；为空表示全平台
  platform              app_versions_platform_enum?
  /// 版本号字符串（如 "2.3.1"）
  version               String                       @db.VarChar(50)
  /// 版本号整数（用于比较大小，如 231）
  versionCode           Int
  /// 更新类型：optional=可选更新, force=强制更新
  updateType            app_versions_updateType_enum @default(optional)
  /// 版本更新标题
  title                 String                       @db.VarChar(255)
  /// 版本更新说明（ChangeLog）
  description           String
  /// 最低支持版本号字符串（低于此版本必须强制更新）
  minSupportVersion     String?                      @db.VarChar(50)
  /// 最低支持版本整数
  minSupportVersionCode Int?
  /// 发布状态：draft=草稿, published=已发布, archived=已归档
  status                app_versions_status_enum     @default(draft)
  /// 是否开启灰度发布
  grayRelease           Boolean                      @default(false)
  /// 灰度发布比例 0-100（百分比）
  grayPercent           Int                          @default(0)
  /// 计划发布时间
  releaseDate           DateTime?                    @db.Timestamptz(6)
  /// 多语言描述（JSON，key=locale，value=描述文字）
  i18nDescription       Json?
  /// 扩展元数据
  metadata              Json?
  /// 创建时间
  createdAt             DateTime                     @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt             DateTime                     @default(now()) @db.Timestamptz(6)
  appVersionPackages    AppVersionPackages[]

  @@unique([platform, version], map: "IDX_6222da359534e48044dce6829e")
  @@map("app_versions")
}

/// 挑战任务配置表 — 定义各类打卡/挑战活动的规则和奖励
model Challenges {
  /// 主键 UUID
  id           String  @id(map: "PK_1e664e93171e20fe4d6125466af") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 挑战标题（如 "7天低脂挑战"）
  title        String  @db.VarChar(100)
  /// 挑战详情描述
  description  String?
  /// 挑战类型（如 calorie/nutrition/streak/weight）
  type         String? @db.VarChar(30)
  /// 挑战持续天数
  durationDays Int     @map("duration_days")
  /// 挑战规则（JSON，如每日目标、判定条件等）
  rules        Json?
  /// 是否当前可报名/展示
  isActive     Boolean @default(true) @map("is_active")

  @@map("challenges")
}

/// 客户端能力权限配置表 — 控制每个 API 客户端可调用的 AI 能力及其限流/配额规则
model ClientCapabilityPermissions {
  /// 主键 UUID
  id                String   @id(map: "PK_c1a6818a8b4efddd7f349efd371") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的客户端 ID（外键 → clients.id）
  clientId          String   @map("client_id") @db.Uuid
  /// 能力类型（如 text.generation/image.generation/text.embedding 等）
  capabilityType    String   @map("capability_type") @db.VarChar(100)
  /// 是否启用该能力
  enabled           Boolean  @default(true)
  /// 每分钟请求限制（QPS 上限）
  rateLimit         Int      @default(60) @map("rate_limit")
  /// 配额总量上限（如每月 Token 数，null=不限制）
  quotaLimit        BigInt?  @map("quota_limit")
  /// 首选 AI 提供商（如 openai/anthropic/qwen）
  preferredProvider String?  @map("preferred_provider") @db.VarChar(50)
  /// 允许使用的提供商列表（逗号分隔）
  allowedProviders  String?  @map("allowed_providers")
  /// 允许使用的模型列表（逗号分隔）
  allowedModels     String?  @map("allowed_models")
  /// 额外配置（JSON）
  config            Json?
  /// 创建时间
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  clients           Clients  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_ad53318f3e760401ed26580a61a")

  @@unique([clientId, capabilityType], map: "IDX_60603413d17812e8ef04288227")
  @@map("client_capability_permissions")
}

/// API 客户端接入凭证表 — 管理第三方或内部服务的 API 访问密钥和配额
model Clients {
  /// 主键 UUID
  id                          String                        @id(map: "PK_f1ab7cf3a5714dbc6bb4e1c28a4") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 客户端名称（如 "admin-panel"、"mobile-app"）
  name                        String                        @db.VarChar(255)
  /// API Key（用于请求认证，全局唯一）
  apiKey                      String                        @unique(map: "IDX_740fe6d4fd0cd0ff47d766c8e0") @map("api_key") @db.VarChar(255)
  /// API Secret（与 API Key 配对，用于签名验证）
  apiSecret                   String                        @map("api_secret") @db.VarChar(255)
  /// 客户端状态（active=正常, inactive=停用）
  status                      String                        @default("active") @db.VarChar(20)
  /// 总配额配置（JSON，如每月 Token 上限、并发数等）
  quotaConfig                 Json?                         @map("quota_config")
  /// 客户端描述
  description                 String?
  /// 扩展元数据（JSON）
  metadata                    Json?
  /// 创建时间
  createdAt                   DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt                   DateTime                      @default(now()) @map("updated_at") @db.Timestamptz(6)
  clientCapabilityPermissions ClientCapabilityPermissions[]

  @@map("clients")
}

/// AI 健康教练会话表 — 一个会话包含多轮对话，对应用户与 AI Coach 的一次完整交流
model CoachConversations {
  /// 主键 UUID
  id            String          @id(map: "PK_a39c641e9cb65d97f4297f6e48e") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的用户 ID
  userId        String          @map("user_id") @db.Uuid
  /// 会话标题（可由 AI 自动生成或用户命名）
  title         String?         @db.VarChar(200)
  /// 会话创建时间
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间（有新消息时更新）
  updatedAt     DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  appUsers      AppUsers        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_28e39678e3cbc5deced6c3b5f7e")
  coachMessages CoachMessages[]

  @@index([userId, updatedAt], map: "IDX_64b7c797968982036808dd8928")
  @@index([userId, updatedAt(sort: Desc)], map: "idx_coach_conversations_user")
  @@map("coach_conversations")
}

/// AI 教练消息表 — 存储会话中每一条用户或 AI 消息
model CoachMessages {
  /// 主键 UUID
  id                 String             @id(map: "PK_d739031ac3c1470a4d96a9bfe8f") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的会话 ID
  conversationId     String             @map("conversation_id") @db.Uuid
  /// 消息角色：user=用户发送, assistant=AI 回复, system=系统消息
  role               String             @db.VarChar(20)
  /// 消息正文（Markdown 格式）
  content            String
  /// 本条消息消耗的 Token 数（0 表示系统消息或未统计）
  tokensUsed         Int                @default(0) @map("tokens_used")
  /// 消息创建时间
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  coachConversations CoachConversations @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_10a0fc9e61c8d70b657decdc02c")

  @@index([conversationId, createdAt], map: "IDX_ce15bf83d158339d1460ef5046")
