/// 全球化食物库主表 — 存储食物的营养、属性、来源及推荐引擎所需的全部字段
/// 字段分组：基本信息 → 宏量营养素 → 微量营养素 → 健康评估 → 标签与决策 →
///           份量 → 烹饪与风味 → 媒体 → 数据溯源 → 向量检索
model foods {
  // ─── 基本信息 ───────────────────────────────────────────────────────────
  /// 主键 UUID
  id                    String                 @id(map: "PK_0cc83421325632f61fa27a52b59") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 食物编码，全局唯一（如 CN_RICE_WHITE_COOKED）
  code                  String                 @unique(map: "IDX_94114b6498bb8a8c102e194b8c") @db.VarChar(50)
  /// 食物标准中文名，全局唯一
  name                  String                 @unique(map: "UQ_c3cf46642750fce8fea692ad946") @db.VarChar(100)
  /// 别名/俗称，逗号分隔（如"米饭,白饭,蒸米"），用于模糊搜索
  aliases               String?                @db.VarChar(300)
  /// 商品条形码（EAN-13 / UPC）
  barcode               String?                @db.VarChar(50)
  /// 生命周期状态：draft=草稿, active=上线, archived=归档, merged=已合并
  status                String                 @default("draft") @db.VarChar(20)
  /// 一级分类（grain/vegetable/fruit/meat/seafood/dairy/egg/legume/nut/fat/beverage/condiment/snack/other）
  category              String                 @db.VarChar(30)
  /// 二级分类（如 grain → white_rice/brown_rice）
  sub_category          String?                @db.VarChar(50)
  /// 食物组（如 USDA 食物组分类）
  food_group            String?                @db.VarChar(30)
  /// 食物形态：ingredient=原材料, dish=成品菜, semi_prepared=半成品（V7.3）
  food_form             String?                @default("ingredient") @db.VarChar(20)
  /// 成品菜推荐优先级 0-100，值越高越优先推荐；仅 dish/semi_prepared 有值（V7.3）
  dish_priority         Int?
  /// 食物可获得性难度 1-5（1=随处可得, 2=常见, 3=普通, 4=较难, 5=稀有）（V7.4）
  acquisition_difficulty Int?                   @default(3)

  // ─── 宏量营养素（per 100g 可食部分）────────────────────────────────────
  /// 热量，单位 kcal
  calories              Decimal                @db.Decimal(7, 1)
  /// 蛋白质，单位 g
  protein               Decimal?               @db.Decimal(6, 1)
  /// 脂肪总量，单位 g
  fat                   Decimal?               @db.Decimal(6, 1)
  /// 碳水化合物，单位 g
  carbs                 Decimal?               @db.Decimal(6, 1)
  /// 膳食纤维，单位 g
  fiber                 Decimal?               @db.Decimal(5, 1)
  /// 总糖（添加糖 + 天然糖），单位 g
  sugar                 Decimal?               @db.Decimal(5, 1)
  /// 添加糖，单位 g
  added_sugar           Decimal?               @db.Decimal(5, 1)
  /// 天然糖，单位 g
  natural_sugar         Decimal?               @db.Decimal(5, 1)
  /// 饱和脂肪，单位 g
  saturated_fat         Decimal?               @db.Decimal(5, 1)
  /// 反式脂肪，单位 g
  trans_fat             Decimal?               @db.Decimal(5, 2)
  /// 胆固醇，单位 mg
  cholesterol           Decimal?               @db.Decimal(6, 1)

  // ─── 微量营养素（per 100g）──────────────────────────────────────────────
  /// 钠，单位 mg
  sodium                Decimal?               @db.Decimal(7, 1)
  /// 钾，单位 mg
  potassium             Decimal?               @db.Decimal(7, 1)
  /// 钙，单位 mg
  calcium               Decimal?               @db.Decimal(7, 1)
  /// 铁，单位 mg
  iron                  Decimal?               @db.Decimal(5, 2)
  /// 维生素 A，单位 μg RAE
  vitamin_a             Decimal?               @db.Decimal(7, 1)
  /// 维生素 C，单位 mg
  vitamin_c             Decimal?               @db.Decimal(6, 1)
  /// 维生素 D，单位 μg
  vitamin_d             Decimal?               @db.Decimal(5, 2)
  /// 维生素 E，单位 mg α-TE
  vitamin_e             Decimal?               @db.Decimal(5, 2)
  /// 维生素 B12，单位 μg
  vitamin_b12           Decimal?               @db.Decimal(5, 2)
  /// 维生素 B6，单位 mg
  vitamin_b6            Decimal?               @db.Decimal(5, 2)
  /// 叶酸，单位 μg DFE
  folate                Decimal?               @db.Decimal(6, 1)
  /// 锌，单位 mg
  zinc                  Decimal?               @db.Decimal(5, 2)
  /// 镁，单位 mg
  magnesium             Decimal?               @db.Decimal(6, 1)
  /// 磷，单位 mg
  phosphorus            Decimal?               @db.Decimal(7, 1)
  /// 嘌呤，单位 mg（痛风饮食管理关键字段）
  purine                Decimal?               @db.Decimal(7, 1)

  // ─── V7.4 Phase 3-A: 精细化营养字段 ──────────────────────────────────
  /// Omega-3 脂肪酸 (EPA+DHA+ALA)，单位 mg
  omega3                Decimal?               @db.Decimal(7, 1)
  /// Omega-6 脂肪酸 (亚油酸为主)，单位 mg
  omega6                Decimal?               @db.Decimal(7, 1)
  /// 可溶性膳食纤维，单位 g（果胶/β-葡聚糖/菊粉等，有助降血脂血糖）
  soluble_fiber         Decimal?               @db.Decimal(5, 1)
  /// 不可溶性膳食纤维，单位 g（纤维素/半纤维素/木质素等，有助肠道蠕动）
  insoluble_fiber       Decimal?               @db.Decimal(5, 1)

  // ─── 健康评估 ──────────────────────────────────────────────────────────
  /// 血糖生成指数 GI（0-100，>70 为高 GI）
  glycemic_index        Int?
  /// 血糖负荷 GL = GI × 碳水/100
  glycemic_load         Decimal?               @db.Decimal(5, 1)
  /// 是否为加工食品
  is_processed          Boolean                @default(false)
  /// 是否为油炸食品
  is_fried              Boolean                @default(false)
  /// 加工程度 1-4（1=未加工, 2=轻加工, 3=中度加工, 4=深度加工/超加工）
  processing_level      Int                    @default(1)
  /// FODMAP 含量等级：low/medium/high（肠易激综合征饮食管理）
  fodmap_level          String?                @db.VarChar(10)
  /// 草酸含量等级：low/medium/high（肾结石防控）
  oxalate_level         String?                @db.VarChar(10)
  /// 过敏原列表（JSON 数组，如 ["gluten","dairy","nuts"]）
  allergens             Json                   @default("[]")
  /// 综合品质分 1-10（营养密度 × 加工程度 × 食材天然性的综合评估）
  quality_score         Decimal?               @db.Decimal(3, 1)
  /// 饱腹感评分 1-10（基于蛋白质、纤维、体积密度估算）
  satiety_score         Decimal?               @db.Decimal(3, 1)
  /// 营养密度评分（基于微量营养素丰富度，单位热量中营养价值的综合评分）
  nutrient_density      Decimal?               @db.Decimal(5, 1)

  // ─── 标签与推荐决策 ────────────────────────────────────────────────────
  /// 适用餐次（JSON 数组，如 ["breakfast","lunch","dinner","snack"]）
  meal_types            Json                   @default("[]")
  /// 自由标签（JSON 数组，如 ["低卡","高蛋白","减脂友好"]）
  tags                  Json                   @default("[]")
  /// 主要食材（单个，如"猪肉"）；多食材请使用 ingredient_list
  /// @deprecated 请优先使用 ingredient_list（V7.1 起支持多食材）
  main_ingredient       String?                @db.VarChar(50)
  /// 完整食材清单（字符串数组，V7.1 取代单一 main_ingredient）
  ingredient_list       String[]               @default([])
  /// 食材兼容性映射（JSON，如 {"avoid":["红酒"],"pair_well":["豆腐"]}）
  compatibility         Json                   @default("{}")
  /// 可获取渠道（JSON 数组）：home_cook=家庭自制, restaurant=餐厅, delivery=外卖, convenience=便利店/超市
  available_channels    Json                   @default("[\"home_cook\",\"restaurant\",\"delivery\",\"convenience\"]")
  /// 大众化评分 0-100（0=极罕见食材, 50=一般常见, 100=日常必备）；影响推荐权重
  commonality_score     Int                    @default(50)

  // ─── 份量信息 ──────────────────────────────────────────────────────────
  /// 标准份量，单位 g（默认 100g）
  standard_serving_g    Int                    @default(100)
  /// 标准份量文字描述（如"1碗(200g)"）
  standard_serving_desc String?                @db.VarChar(100)
  /// 常见份量预设（JSON 数组，如 [{"name":"1碗","grams":200},{"name":"半碗","grams":100}]）
  common_portions       Json                   @default("[]")

  // ─── 烹饪与风味 ────────────────────────────────────────────────────────
  /// 所属菜系（如 chinese/japanese/western/korean/indian）
  cuisine               String?                @db.VarChar(30)
  /// 风味画像（JSON，如 {"salty":4,"sweet":1,"spicy":0,"umami":3}，0-5 分制）
  flavor_profile        Json?
  /// 主要烹饪方式（单个，如 steam/boil/fry）；多方式请使用 cooking_methods
  /// @deprecated 请优先使用 cooking_methods（V7.1 起支持多烹饪方式）
  cooking_method        String?                @db.VarChar(20)
  /// 可行烹饪方式列表（字符串数组，如 ["steam","boil","stir_fry"]，V7.1 取代单一 cooking_method）
  cooking_methods       String[]               @default([])
  /// 所需厨房设备（字符串数组，如 ["oven","wok"]；none=无需特殊设备）
  required_equipment    String[]               @default([])
  /// 建议食用温度：hot=热食, warm=温食, cold=冷食, room_temp=常温
  serving_temperature   String?                @db.VarChar(20)
  /// 口感标签（字符串数组，如 ["crispy","chewy"]：crispy/creamy/chewy/soft/crunchy）
  texture_tags          String[]               @default([])
  /// 成品类型：dish=菜肴, soup=汤, drink=饮品, dessert=甜点, snack=零食, staple=主食
  dish_type             String?                @db.VarChar(20)
  /// 备料时间，单位分钟
  prep_time_minutes     Int?
  /// 烹饪时间，单位分钟
  cook_time_minutes     Int?
  /// 烹饪难度：easy/medium/hard
  skill_required        String?                @db.VarChar(10)
  /// 成本等级 1-5（1=极低/食堂价, 3=中等/家常价, 5=高端/餐厅价）
  estimated_cost_level  Int?
  /// 保质期，单位天（0 表示当日食用）
  shelf_life_days       Int?
  /// 含水率百分比（0-100，用于水分摄入评估）
  water_content_percent Decimal?               @db.Decimal(5, 2)

  // ─── 媒体资源 ──────────────────────────────────────────────────────────
  /// 食物完整图片 URL
  image_url             String?                @db.VarChar(500)
  /// 食物缩略图 URL（列表展示用）
  thumbnail_url         String?                @db.VarChar(500)

  // ─── 数据溯源与质控 ────────────────────────────────────────────────────
  /// 主要数据来源标识（manual=人工录入, usda=USDA, cfsb=中国食物成分表, ai=AI生成, import=批量导入）
  primary_source        String                 @default("manual") @db.VarChar(50)
  /// 主要数据来源的原始 ID（如 USDA FDC ID）
  primary_source_id     String?                @db.VarChar(100)
  /// @deprecated 与 primary_source 重叠，旧版残留字段，后续迁移中将移除
  source                String?                @default("official") @db.VarChar(20)
  /// 数据版本号，每次更新递增
  data_version          Int                    @default(1)
  /// AI/算法对该条数据的置信度 0.00-1.00
  confidence            Decimal                @default(1) @db.Decimal(3, 2)
  /// 是否已经过人工或专业机构核验
  is_verified           Boolean                @default(false)
  /// 核验人（用户名或机构名）
  verified_by           String?                @db.VarChar(100)
  /// 核验时间
  verified_at           DateTime?              @db.Timestamptz(6)
  /// 搜索权重（影响列表排序，默认 100；可人工调高热门食物）
  search_weight         Int                    @default(100)
  /// 用户点击/使用次数（由行为事件自动累积）
  popularity            Int                    @default(0)
  /// 创建时间
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updated_at            DateTime               @default(now()) @db.Timestamptz(6)

  // ─── V8.0: 补全元数据（AI 补全辅助字段）──────────────────────────────────
  /// V8.0: 数据完整度评分 0-100（加权计算，定期更新）
  data_completeness     Int                    @default(0)
  /// V8.0: 补全状态 pending/partial/completed/failed
  enrichment_status     String                 @default("pending") @db.VarChar(20)
  /// V8.0: 最后一次 AI 补全时间
  last_enriched_at      DateTime?              @db.Timestamptz(6)
  /// V8.0: 字段级数据来源，如 {"protein":"ai_enrichment","fat":"manual","carbs":"usda"}
  field_sources         Json                   @default("{}")
  /// V8.0: 字段级置信度，如 {"protein":0.85,"fat":0.92}
  field_confidence      Json                   @default("{}")

  // ─── 向量检索（AI 语义搜索）────────────────────────────────────────────
  /// 语义向量（float32 数组，用于余弦相似度搜索；v4 模型）
  embedding             Float[]                @db.Real
  /// v4 向量最后更新时间
  embedding_updated_at  DateTime?              @db.Timestamptz(6)
  /// 语义向量（pgvector 原生类型，v5 模型；支持 <=> 余弦距离操作符）
  embedding_v5          Unsupported("vector")?

  // ─── 关联关系（反向引用，不存储于本表）───────────────────────────────────
  analysis_food_link    analysis_food_link[]
  daily_plan_items      daily_plan_items[]
  food_change_logs      food_change_logs[]
  food_conflicts        food_conflicts[]
  food_regional_info    food_regional_info[]
  food_sources          food_sources[]
  food_translations     food_translations[]
  recipe_ingredients    recipe_ingredients[]

  @@index([search_weight], map: "IDX_5f8b45ec9d0608cffe04d3afbe")
  @@index([allergens], map: "IDX_foods_allergens_gin", type: Gin)
  @@index([barcode], map: "IDX_foods_barcode")
  @@index([meal_types], map: "IDX_foods_meal_types_gin", type: Gin)
  @@index([primary_source], map: "IDX_foods_primary_source")
  @@index([status], map: "IDX_foods_status")
  @@index([tags], map: "IDX_foods_tags_gin", type: Gin)
  @@index([cooking_method], map: "idx_food_library_cooking_method")
  @@index([cuisine], map: "idx_food_library_cuisine")
  @@index([category], map: "idx_foods_category")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_foods_name_trgm", type: Gin)
  @@index([search_weight(sort: Desc)], map: "idx_foods_weight")
  @@index([is_verified, category], map: "idx_foods_verified_category")
  @@index([aliases(ops: raw("gin_trgm_ops"))], map: "idx_foods_aliases_trgm", type: Gin)
  @@index([commonality_score], map: "idx_foods_commonality")
  @@index([food_form], map: "idx_foods_food_form")
  @@index([enrichment_status], map: "idx_foods_enrichment_status")
  @@index([data_completeness], map: "idx_foods_data_completeness")
