/// 全球化食物库主表 — 存储食物的营养、属性、来源及推荐引擎所需的全部字段
/// 字段分组：基本信息 → 宏量营养素 → 微量营养素 → 健康评估 → 标签与决策 →
///           份量 → 烹饪与风味 → 媒体 → 数据溯源 → 向量检索
/// 食物主表（原 model Foods，重构后改名为 Food，物理表名通过 @@map 保留为 "foods"）
/// embedding 系列、failed_fields 字段已迁移至 FoodEmbedding / FoodFieldProvenance 关联表
model Food {
  // ─── 基本信息 ───────────────────────────────────────────────────────────
  /// 主键 UUID
  id                    String  @id(map: "PK_0cc83421325632f61fa27a52b59") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 食物编码，全局唯一（如 CN_RICE_WHITE_COOKED）
  code                  String  @unique(map: "IDX_94114b6498bb8a8c102e194b8c") @db.VarChar(50)
  /// 食物标准中文名，全局唯一
  name                  String  @unique(map: "UQ_c3cf46642750fce8fea692ad946") @db.VarChar(255)
  /// 别名/俗称，逗号分隔（如"米饭,白饭,蒸米"），用于模糊搜索
  aliases               String? @db.Text
  /// 商品条形码（EAN-13 / UPC）
  barcode               String? @db.VarChar(50)
  /// 生命周期状态：draft=草稿, active=上线, archived=归档, merged=已合并
  status                String  @default("draft") @db.VarChar(20)
  /// 一级分类（grain/vegetable/fruit/meat/seafood/dairy/egg/legume/nut/fat/beverage/condiment/snack/other）
  category              String  @db.VarChar(30)
  /// 二级分类（如 grain → white_rice/brown_rice）
  subCategory           String? @map("sub_category") @db.VarChar(255)
  /// 食物组（如 USDA 食物组分类）
  foodGroup             String? @map("food_group") @db.VarChar(255)
  /// 食物形态：ingredient=原材料, dish=成品菜, semi_prepared=半成品（V7.3）
  foodForm              String? @map("food_form") @db.VarChar(20)
  /// 成品菜推荐优先级 0-100，值越高越优先推荐；仅 dish/semi_prepared 有值（V7.3）
  dishPriority          Int?    @map("dish_priority")
  /// 食物可获得性难度 1-5（1=随处可得, 2=常见, 3=普通, 4=较难, 5=稀有）（V7.4）
  acquisitionDifficulty Int?    @map("acquisition_difficulty")

  // ─── 宏量营养素（per 100g 可食部分）────────────────────────────────────
  /// 热量，单位 kcal
  calories  Decimal  @db.Decimal(7, 1)
  /// 蛋白质，单位 g
  protein   Decimal? @db.Decimal(6, 1)
  /// 脂肪总量，单位 g
  fat       Decimal? @db.Decimal(6, 1)
  /// 碳水化合物，单位 g
  carbs     Decimal? @db.Decimal(6, 1)
  /// 膳食纤维，单位 g
  fiber     Decimal? @db.Decimal(5, 1)
  /// 总糖（添加糖 + 天然糖），单位 g
  sugar     Decimal? @db.Decimal(5, 1)
  /// 钠，单位 mg
  sodium    Decimal? @db.Decimal(7, 1)
  /// 钾，单位 mg
  potassium Decimal? @db.Decimal(7, 1)
  /// 钙，单位 mg
  calcium   Decimal? @db.Decimal(7, 1)
  /// 铁，单位 mg
  iron      Decimal? @db.Decimal(5, 2)

  // ─── 健康评估（已迁移至 food_health_assessments，读写通过关联表）───────
  // glycemicIndex / glycemicLoad / isProcessed / isFried / processingLevel
  // fodmapLevel / oxalateLevel / allergens / qualityScore / satietyScore / nutrientDensity
  // → 见 FoodHealthAssessment / FoodTaxonomy 模型

  // ─── 标签与推荐决策 ────────────────────────────────────────────────────
  // mealTypes / tags / allergens / compatibility / availableChannels
  // → 已迁移至 food_taxonomies，见 FoodTaxonomy 模型
  /// 主要食材（单个，如"猪肉"）；多食材请使用 ingredient_list
  /// @deprecated [DEPRECATED-V7.1 / ARB-2026-04] DO NOT USE in new code.
  /// Replaced by `ingredientList` (string[]). Will be DROPPED in V9.
  /// All reads must fall back to ingredientList[0]; all writes are forbidden.
  mainIngredient   String?  @map("main_ingredient") @db.VarChar(255)
  /// 完整食材清单（字符串数组，V7.1 取代单一 main_ingredient）
  ingredientList   String[] @default([]) @map("ingredient_list")
  /// 大众化评分 0-100（0=极罕见食材, 50=一般常见, 100=日常必备）；影响推荐权重
  commonalityScore Int      @map("commonality_score")

  // ─── 份量/烹饪/风味（已迁移至 food_portion_guides / food_taxonomies）────
  // standardServingG / standardServingDesc / commonPortions / cookingMethods
  // requiredEquipment / servingTemperature / textureTags / dishType
  // prepTimeMinutes / cookTimeMinutes / skillRequired / estimatedCostLevel
  // shelfLifeDays / waterContentPercent / cuisine / flavorProfile
  // → 见 FoodPortionGuide / FoodTaxonomy 模型

  // ─── 媒体资源 ──────────────────────────────────────────────────────────
  /// 食物完整图片 URL
  imageUrl     String? @map("image_url") @db.VarChar(500)
  /// 食物缩略图 URL（列表展示用）
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // ─── 数据溯源与质控 ────────────────────────────────────────────────────
  /// 主要数据来源标识（manual=人工录入, usda=USDA, cfsb=中国食物成分表, ai=AI生成, import=批量导入）
  primarySource   String    @default("manual") @map("primary_source") @db.VarChar(50)
  /// 主要数据来源的原始 ID（如 USDA FDC ID）
  primarySourceId String?   @map("primary_source_id") @db.VarChar(255)
  /// @deprecated [DEPRECATED / ARB-2026-04] DO NOT USE in new code.
  /// Replaced by `primarySource`. Will be DROPPED in V9.
  /// All new writes must target primarySource only.
  source          String?   @default("official") @db.VarChar(20)
  /// 数据版本号，每次更新递增
  dataVersion     Int       @default(1) @map("data_version")
  /// AI/算法对该条数据的置信度 0.00-1.00
  confidence      Decimal   @default(1) @db.Decimal(3, 2)
  /// 是否已经过人工或专业机构核验
  isVerified      Boolean   @default(false) @map("is_verified")
  /// 核验人（用户名或机构名）
  verifiedBy      String?   @map("verified_by") @db.VarChar(100)
  /// 核验时间
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz(6)
  /// 搜索权重（影响列表排序，默认 100；可人工调高热门食物）
  searchWeight    Int       @default(100) @map("search_weight")
  /// 用户点击/使用次数（由行为事件自动累积）
  popularity      Int?      @default(0)
  /// 创建时间
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  // ─── V8.0: 补全元数据（AI 补全辅助字段）──────────────────────────────────
  /// V8.0: 数据完整度评分 0-100（加权计算，定期更新）
  dataCompleteness Int       @default(0) @map("data_completeness")
  /// V8.0: 补全状态 pending/partial/completed/failed
  enrichmentStatus String    @default("pending") @map("enrichment_status") @db.VarChar(20)
  /// V8.1: 食物整体审核状态 pending/approved/rejected（由运营人员手动标记，独立于 enrichment_status）
  reviewStatus     String    @default("pending") @map("review_status") @db.VarChar(20)
  /// V8.0: 最后一次 AI 补全时间
  lastEnrichedAt   DateTime? @map("last_enriched_at") @db.Timestamptz(6)
  /// V8.1: 最近审核者用户名
  reviewedBy       String?   @map("reviewed_by") @db.VarChar(100)
  /// V8.1: 最近审核时间
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(6)

  // ─── V8.2 重构：embedding/failed_fields 字段已迁移至关联表 ──────────────────
  //   embedding / embedding_v5 / embedding_updated_at → FoodEmbedding
  //   failed_fields                                  → FoodFieldProvenance (status='failed')
  //   field_sources / field_confidence               → FoodFieldProvenance (status='success')

  // ─── 关联关系（反向引用，不存储于本表）───────────────────────────────────
  analysisFoodLink  AnalysisFoodLink[]
  dailyPlanItems    DailyPlanItems[]
  foodChangeLogs    FoodChangeLogs[]
  foodConflicts     FoodConflicts[]
  foodRegionalInfo  FoodRegionalInfo[]
  foodSources       FoodSources[]
  foodTranslations  FoodTranslations[]
  recipeIngredients RecipeIngredients[]
  embeddings        FoodEmbedding[]
  fieldProvenance   FoodFieldProvenance[]
  nutritionDetail   FoodNutritionDetail?
  healthAssessment  FoodHealthAssessment?
  taxonomy          FoodTaxonomy?
  portionGuide      FoodPortionGuide?

  @@index([searchWeight], map: "IDX_5f8b45ec9d0608cffe04d3afbe")
  @@index([barcode], map: "IDX_foods_barcode")
  @@index([primarySource], map: "IDX_foods_primary_source")
  @@index([status], map: "IDX_foods_status")
  @@index([category], map: "idx_foods_category")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_foods_name_trgm", type: Gin)
  @@index([searchWeight(sort: Desc)], map: "idx_foods_weight")
  @@index([isVerified, category], map: "idx_foods_verified_category")
  @@index([aliases(ops: raw("gin_trgm_ops"))], map: "idx_foods_aliases_trgm", type: Gin)
  @@index([commonalityScore], map: "idx_foods_commonality")
  @@index([foodForm], map: "idx_foods_food_form")
  @@index([enrichmentStatus], map: "idx_foods_enrichment_status")
  @@index([reviewStatus], map: "idx_foods_review_status")
  @@index([dataCompleteness], map: "idx_foods_data_completeness")
  @@index([lastEnrichedAt], map: "idx_foods_last_enriched_at")
  @@map("foods")
}

// ============================================================================
// ARB-2026-04: Food god-table split — 4 张领域 1:1 关联表
// 设计原则：
//   1. 主表 foods 大部分领域列已于 migration 20260506000000 中 DROP
//   2. sodium/potassium/calcium/iron 仍保留在 foods 主表
//   3. 其余读写通过拆分表进行（include: FOOD_SPLIT_INCLUDE）
//   4. 双写路径：food-library / food-enrichment / food-pipeline-orchestrator
// ============================================================================

/// V8.3 拆分表：微量营养与精细化营养字段（per 100g）
/// 与 foods 1:1 关联；非核心匹配字段，承载所有维生素/矿物质/特殊脂肪酸细节
model FoodNutritionDetail {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  foodId String @unique @map("food_id") @db.Uuid

  // 维生素
  vitaminA   Decimal? @map("vitamin_a") @db.Decimal(7, 1)
  vitaminC   Decimal? @map("vitamin_c") @db.Decimal(6, 1)
  vitaminD   Decimal? @map("vitamin_d") @db.Decimal(5, 2)
  vitaminE   Decimal? @map("vitamin_e") @db.Decimal(5, 2)
  vitaminB6  Decimal? @map("vitamin_b6") @db.Decimal(5, 2)
  vitaminB12 Decimal? @map("vitamin_b12") @db.Decimal(5, 2)
  folate     Decimal? @db.Decimal(6, 1)

  // 矿物质（除主表保留的 sodium/potassium/calcium/iron 外）
  zinc       Decimal? @db.Decimal(5, 2)
  magnesium  Decimal? @db.Decimal(6, 1)
  phosphorus Decimal? @db.Decimal(7, 1)
  purine     Decimal? @db.Decimal(7, 1)

  // 脂质细分
  cholesterol  Decimal? @db.Decimal(6, 1)
  saturatedFat Decimal? @map("saturated_fat") @db.Decimal(5, 1)
  transFat     Decimal? @map("trans_fat") @db.Decimal(5, 2)
  omega3       Decimal? @db.Decimal(7, 1)
  omega6       Decimal? @db.Decimal(7, 1)

  // 糖与纤维细分
  addedSugar     Decimal? @map("added_sugar") @db.Decimal(5, 1)
  naturalSugar   Decimal? @map("natural_sugar") @db.Decimal(5, 1)
  solubleFiber   Decimal? @map("soluble_fiber") @db.Decimal(5, 1)
  insolubleFiber Decimal? @map("insoluble_fiber") @db.Decimal(5, 1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("food_nutrition_details")
}

/// V8.3 拆分表：健康评估字段（GI/GL、加工程度、品质评分等）
/// 与 foods 1:1 关联；这些字段独立于基础营养，便于专项健康场景查询与索引
model FoodHealthAssessment {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  foodId String @unique @map("food_id") @db.Uuid

  glycemicIndex   Int?     @map("glycemic_index")
  glycemicLoad    Decimal? @map("glycemic_load") @db.Decimal(5, 1)
  isProcessed     Boolean? @map("is_processed")
  isFried         Boolean? @map("is_fried")
  processingLevel Int?     @map("processing_level")
  fodmapLevel     String?  @map("fodmap_level") @db.VarChar(10)
  oxalateLevel    String?  @map("oxalate_level") @db.VarChar(10)
  qualityScore    Decimal? @map("quality_score") @db.Decimal(3, 1)
  satietyScore    Decimal? @map("satiety_score") @db.Decimal(3, 1)
  nutrientDensity Decimal? @map("nutrient_density") @db.Decimal(5, 1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([qualityScore], map: "idx_food_health_quality_score")
  @@index([processingLevel], map: "idx_food_health_processing_level")
  @@map("food_health_assessments")
}

/// V8.3 拆分表：分类、标签、兼容性、过敏原
/// 与 foods 1:1 关联；以 JSON / 数组承载推荐与匹配所需的语义维度
model FoodTaxonomy {
  id     String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  foodId String @unique @map("food_id") @db.Uuid

  /// 适用餐次（["breakfast","lunch","dinner","snack"]）
  mealTypes         Json     @default("[]") @map("meal_types")
  /// 自由标签
  tags              Json     @default("[]")
  /// 过敏原列表
  allergens         Json     @default("[]")
  /// 食材兼容性映射
  compatibility     Json     @default("{}")
  /// 可获取渠道
  availableChannels Json     @default("[\"home_cook\",\"restaurant\",\"delivery\",\"convenience\"]") @map("available_channels")
  /// 风味画像
  flavorProfile     Json?    @map("flavor_profile")
  /// 口感标签
  textureTags       String[] @default([]) @map("texture_tags")
  /// 所属菜系
  cuisine           String?  @db.VarChar(100)
  /// 成品类型
  dishType          String?  @map("dish_type") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

