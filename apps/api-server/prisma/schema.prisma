/// AI 能力调用记录表 — 记录每次 API 请求的提供商、模型、费用和响应时间，用于成本分析
model UsageRecords {
  /// 主键 UUID
  id             String   @id(map: "PK_e511cf9f7dc53851569f87467a5") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 调用方客户端 ID
  clientId       String   @map("client_id") @db.Uuid
  /// 调用用户 ID（可选，系统级任务为空）
  userId         String?  @map("user_id") @db.Uuid
  /// 请求唯一 ID（用于去重和追踪）
  requestId      String   @map("request_id") @db.VarChar(255)
  /// 调用的能力类型（如 text.generation/image.generation）
  capabilityType String   @map("capability_type") @db.VarChar(100)
  /// 实际使用的 AI 提供商（如 openai/anthropic）
  provider       String   @db.VarChar(50)
  /// 实际使用的模型名称（如 gpt-4o）
  model          String   @db.VarChar(100)
  /// 请求状态：success=成功, failed=失败, timeout=超时
  status         String   @db.VarChar(20)
  /// Token 使用量（JSONB，含 prompt_tokens/completion_tokens/total_tokens）
  usage          Json
  /// 本次请求费用（单位：美元）
  cost           Decimal  @db.Decimal(10, 6)
  /// 响应时间，单位毫秒
  responseTime   Int      @map("response_time")
  /// 扩展元数据（JSONB）
  metadata       Json?
  /// 请求时间戳
  timestamp      DateTime @default(now()) @db.Timestamptz(6)

  // ── 复合索引（覆盖主要查询模式）──────────────────────────────
  @@index([capabilityType, timestamp(sort: Desc)], map: "idx_usage_records_feature_ts")
  @@index([provider, timestamp(sort: Desc)], map: "idx_usage_records_provider_ts")
  @@index([clientId, timestamp(sort: Desc)], map: "idx_usage_records_client_ts")
  // 按用户查个人消费（配额报表 / 用户侧展示）
  @@index([userId, timestamp(sort: Desc)], map: "idx_usage_records_user_ts")
  // 归档 cron：按时间范围扫描旧记录（timestamp 升序快进）
  @@index([timestamp], map: "idx_usage_records_timestamp")
  // status 过滤（失败率统计 / 告警）
  @@index([status, timestamp(sort: Desc)], map: "idx_usage_records_status_ts")
  @@map("usage_records")
}

/// usage_records 冷归档表（90 天以前的数据按月批量移入）
