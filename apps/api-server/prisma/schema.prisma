/// AI 模型配置表 — 存储每个 Provider 下各模型的能力参数、费率和访问限制
model model_configs {
  /// 主键 UUID
  id                    String                            @id(map: "PK_37b8d27a688c96443f78bdb3e3c") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// 关联的 AI 提供商 ID（外键 → providers.id）
  providerId            String                            @db.Uuid
  /// 模型标识名（如 "gpt-4o"、"claude-3-5-sonnet"）
  modelName             String                            @db.VarChar(100)
  /// 模型展示名称（中文友好名）
  displayName           String                            @db.VarChar(100)
  /// 能力类型：text.generation/text.embedding/image.generation 等
  capabilityType        model_configs_capabilitytype_enum
  /// 是否启用该模型
  enabled               Boolean                           @default(true)
  /// 路由优先级（值越大优先级越高）
  priority              Int                               @default(0)
  /// 模型状态：active=正常, inactive=停用, deprecated=已废弃
  status                model_configs_status_enum         @default(active)
  /// 输入 Token 费率（每千 Token 美元/人民币）
  inputCostPer1kTokens  Decimal                           @db.Decimal(10, 6)
  /// 输出 Token 费率（每千 Token）
  outputCostPer1kTokens Decimal                           @db.Decimal(10, 6)
  /// 计费货币：USD=美元, CNY=人民币
  currency              model_configs_currency_enum       @default(USD)
  /// 单次请求最大 Token 数（输入+输出）
  maxTokens             Int
  /// 每分钟最大请求次数（RPM），null=不限制
  maxRequestsPerMinute  Int?
  /// 上下文窗口大小（Token 数）
  contextWindow         Int
  /// 是否支持流式响应（SSE）
  streaming             Boolean                           @default(false)
  /// 是否支持 Function Calling
  functionCalling       Boolean                           @default(false)
  /// 是否支持图片/视觉输入
  vision                Boolean                           @default(false)
  /// 自定义 API Endpoint（覆盖 Provider 默认地址）
  endpoint              String?                           @db.VarChar(500)
  /// 自定义 API Key（覆盖 Provider 默认 Key，camelCase 版本）
  customApiKey          String?                           @db.VarChar(500)
  /// 自定义超时时间（毫秒，camelCase 版本）
  customTimeout         Int?
  /// 自定义重试次数（camelCase 版本）
  customRetries         Int?
  /// 额外配置元数据（JSON，camelCase 版本）
  configMetadata        Json?
  /// 扩展元数据（JSON）
  metadata              Json?
  /// 创建时间
  createdAt             DateTime                          @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt             DateTime                          @default(now()) @db.Timestamptz(6)
