  updated_at DateTime @updatedAt @db.Timestamptz(6)

  recipe recipes @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@unique([recipe_id, user_id], map: "uq_recipe_rating_recipe_user")
  @@index([user_id], map: "idx_recipe_ratings_user")
  @@index([recipe_id], map: "idx_recipe_ratings_recipe")
}

/// 策略调优历史 — 记录推荐策略自动或手动切换前后的效果对比，用于策略迭代评估
model strategy_tuning_log {
  /// 主键 UUID
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 调优针对的用户分群名称（如 fat_loss_active）
  segment_name      String   @db.VarChar(50)
  /// 切换前使用的策略名称
  previous_strategy String   @db.VarChar(50)
  /// 切换后使用的策略名称
  new_strategy      String   @db.VarChar(50)
  /// 切换前的指标值（如采纳率）
  previous_rate     Float
  /// 切换后的指标值（如采纳率）
  new_rate          Float
  /// 改善幅度（new_rate - previous_rate）
  improvement       Float
  /// 是否由系统自动应用（true=自动，false=人工触发）
  auto_applied      Boolean  @default(false)
  /// 记录创建时间
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([segment_name], map: "idx_stl_segment")
  @@index([created_at], map: "idx_stl_created")
}

/// 替换模式聚合 — 用户 A→B 替换行为的频率统计，用于推荐权重调整
model replacement_patterns {
  /// 主键 UUID
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id        String   @db.Uuid
  /// 被替换的原食物 ID
  from_food_id   String   @db.Uuid
  /// 被替换的原食物名称（冗余存储）
  from_food_name String   @db.VarChar(200)
  /// 替换成的目标食物 ID
  to_food_id     String   @db.Uuid
  /// 替换成的目标食物名称（冗余存储）
  to_food_name   String   @db.VarChar(200)
  /// 该替换发生的总次数
  frequency      Int      @default(1)
  /// 最近一次发生替换的时间
  last_occurred  DateTime @default(now()) @db.Timestamptz(6)
  /// V6.7 Phase 2-E: 替换发生的餐次类型（breakfast/lunch/dinner/snack）
  meal_type      String?  @db.Text
  /// 创建时间
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updated_at     DateTime @updatedAt @db.Timestamptz(6)

  @@unique([user_id, from_food_id, to_food_id], map: "uq_replacement_pattern")
  @@index([user_id], map: "idx_rp_user")
  @@index([from_food_id], map: "idx_rp_from_food")
  @@index([meal_type], map: "idx_rp_meal_type")
}

/// V6.9 Phase 2-C: 推荐执行记录 — 追踪推荐→实际执行的闭环，计算执行率
model recommendation_executions {
  /// 主键 UUID
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id           String    @db.Uuid
  /// 关联的推荐 ID（来源于推荐引擎的请求 ID，可选）
  recommendation_id String?   @db.VarChar(255)
  /// 餐次类型：breakfast/lunch/dinner/snack
  meal_type         String    @db.VarChar(20)
  recommended_foods Json      /// 推荐的食物 ID 列表
  executed_foods    Json?     /// 实际执行的食物 ID 列表（分析结果回填）
  execution_rate    Float?    /// 执行率 0-1（匹配的食物数/推荐的食物数）
  deviation_notes   Json?     /// 偏差记录（替换/增加/减少了什么）
  /// 推荐发出时间
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  /// 用户实际执行（进餐）时间（异步回填）
  executed_at       DateTime? @db.Timestamptz(6)

  @@index([user_id, created_at], map: "idx_rec_exec_user_created")
  @@index([user_id, meal_type], map: "idx_rec_exec_user_meal")
}

/// V6.5 Phase 3J: 暴食干预效果追踪 — 记录每次暴食干预事件及后续行为变化，用于评估干预有效性
model binge_intervention_logs {
  /// 主键 UUID
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id               String   @db.Uuid
  /// 干预触发时段（24h 制）
  trigger_hour          Int      @db.SmallInt
  /// 干预消息内容
  message               String   @db.VarChar(500)
  /// 干预前 2h 卡路里摄入
  pre_calories          Float?
  /// 干预后 3h 卡路里摄入（异步回填）
  post_calories         Float?
  /// 干预是否有效：post_calories < pre_expected 视为有效（异步回填）
  effective             Boolean?
  /// 用户是否在干预后 3h 内新增了食物记录
  had_post_record       Boolean?
  /// 异步评估时间
  evaluated_at          DateTime? @db.Timestamptz(6)
  /// 记录创建时间
  created_at            DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id, created_at], map: "idx_bil_user_created")
  @@index([effective], map: "idx_bil_effective")
}

/// V7.0: 目标阶段表 — 存储 CompoundGoal 中各个阶段的配置与执行状态
model goal_phases {
  /// 主键 UUID
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id            String    @db.Uuid
  goal_type          String    @db.VarChar(50) /// GoalType: fat_loss/muscle_gain/health/habit
  name               String    @db.VarChar(100) /// 阶段名称（用户可见）
  duration_weeks     Int                        /// 阶段持续周数
  calorie_multiplier Float     @default(1.0)    /// 相对 TDEE 的热量调整比例
  macro_ratio_override Json?   @db.JsonB        /// { carb: [min, max], fat: [min, max] }
  phase_order        Int                        /// 阶段顺序（0-based）
  is_active          Boolean   @default(false)  /// 当前是否激活
  started_at         DateTime? @db.Timestamptz(6) /// 阶段开始时间
  completed_at       DateTime? @db.Timestamptz(6) /// 阶段完成时间
  /// 创建时间
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([user_id, is_active], map: "idx_goal_phases_user_active")
  @@index([user_id, phase_order], map: "idx_goal_phases_user_order")
}
