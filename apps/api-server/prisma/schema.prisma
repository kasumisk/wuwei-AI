/// 用户体重历史记录表 — 按时间序列记录每次体重和体脂率的测量值
model weight_history {
  /// 主键 UUID
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id          String   @db.Uuid
  /// 测量体重，单位 kg
  weight_kg        Decimal  @db.Decimal(5, 1)
  /// 测量体脂率，单位 %（可选）
  body_fat_percent Decimal? @db.Decimal(4, 1)
  /// 数据来源：manual=手动录入, scale=智能秤, import=导入
  source           String   @default("manual") @db.VarChar(20)
  /// 测量记录时间
  recorded_at      DateTime @default(now()) @db.Timestamptz(6)
  /// V6.5 Phase 2I: FK 补齐
  user             app_users @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_weight_history_user")

  @@index([user_id, recorded_at], map: "idx_weight_history_user_recorded")
}

/// 提醒关闭记录表 — 记录用户对各类系统提醒的关闭操作，防止重复打扰
model reminder_dismissals {
  /// 主键 UUID
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id       String   @db.Uuid
  /// 提醒类型标识（如 onboarding_tip/calorie_warning/binge_alert）
  reminder_type String   @db.VarChar(50)
  /// 关闭时间
  dismissed_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, reminder_type], map: "uq_reminder_user_type")
  @@index([user_id])
}

/// 菜谱表 — 存储 AI 生成或人工录入的菜谱，包含营养信息、烹饪步骤及审核状态
model recipes {
  /// 主键 UUID
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 菜谱名称
  name                 String               @db.VarChar(200)
  /// 菜谱描述
  description          String?
  /// 菜系（如 chinese/japanese/western/korean）
  cuisine              String?              @db.VarChar(50)
  /// 制作难度：1=简单, 2=中等, 3=较难, 4=困难, 5=专业
  difficulty           Int                  @default(1) @db.SmallInt
  /// 备料时间，单位分钟
  prep_time_minutes    Int?
  /// 烹饪时间，单位分钟
  cook_time_minutes    Int?
  /// 份数（默认 1 人份）
  servings             Int                  @default(1) @db.SmallInt
  /// 标签列表（如 ["低脂","高蛋白","快手菜"]）
  tags                 String[]
  /// 烹饪步骤（JSON 数组，每步含 step/description/image_url）
  instructions         Json?
  /// 菜谱封面图 URL
  image_url            String?              @db.VarChar(500)
  /// 数据来源：ai_generated=AI 生成, user_submitted=用户提交, curated=人工精选
  source               String               @default("ai_generated") @db.VarChar(50)
  /// 每份热量，单位 kcal
  calories_per_serving Decimal?             @db.Decimal(8, 2)
  /// 每份蛋白质，单位 g
  protein_per_serving  Decimal?             @db.Decimal(8, 2)
  /// 每份脂肪，单位 g
  fat_per_serving      Decimal?             @db.Decimal(8, 2)
  /// 每份碳水化合物，单位 g
  carbs_per_serving    Decimal?             @db.Decimal(8, 2)
  /// 每份膳食纤维，单位 g
  fiber_per_serving    Decimal?             @db.Decimal(8, 2)
  /// 综合质量评分 0.00-5.00（AI 评估的营养均衡度、做法完整性等）
  quality_score        Decimal              @default(0) @db.Decimal(5, 2)
  /// 被推荐/引用次数（用于热度排序）
  usage_count          Int                  @default(0)
  /// 审核状态：pending=待审核, approved=已通过, rejected=已拒绝
  review_status        String               @default("approved") @db.VarChar(20)
  /// 提交人用户 ID（用户提交时填写）
  submitted_by         String?              @db.Uuid
  /// 审核人管理员 ID
  reviewed_by          String?              @db.Uuid
  /// 审核时间
  reviewed_at          DateTime?            @db.Timestamptz(6)
  /// 审核备注（拒绝时填写原因）
  review_note          String?
  /// 是否上架（false=下架，不可推荐）
  is_active            Boolean              @default(true)
  available_channels   Json                 @default("[\"home_cook\"]") /// 可获取渠道: home_cook/restaurant/delivery/convenience
  /// 创建时间
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  recipe_ingredients   recipe_ingredients[]
  recipe_translations  recipe_translations[]
  recipe_ratings       recipe_ratings[]
  daily_plan_items     daily_plan_items[]

  @@index([cuisine], map: "idx_recipes_cuisine")
  @@index([difficulty], map: "idx_recipes_difficulty")
  @@index([review_status], map: "idx_recipes_review_status")
  @@index([tags], map: "idx_recipes_tags", type: Gin)
  @@index([quality_score(sort: Desc)], map: "idx_recipes_quality")
}

/// 菜谱食材明细表 — 存储每道菜谱所需的食材列表及用量
model recipe_ingredients {
  /// 主键 UUID
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的菜谱 ID（外键 → recipes.id）
  recipe_id       String   @db.Uuid
  /// 对应食物库中的食物 ID（可选，无精确匹配时为 null）
  food_id         String?  @db.Uuid
  /// 食材名称（展示用，如"鸡胸肉"）
  ingredient_name String   @db.VarChar(100)
  /// 用量数值（如 200）
  amount          Decimal? @db.Decimal(8, 2)
  /// 用量单位（如 g/ml/个/勺）
  unit            String?  @db.VarChar(20)
  /// 是否为可选食材（false=必选，true=可省略）
  is_optional     Boolean  @default(false)
  /// 显示排序（值越小越靠前）
  sort_order      Int      @default(0) @db.SmallInt

  recipe recipes  @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  food   foods?   @relation(fields: [food_id], references: [id], onDelete: SetNull)

  @@index([recipe_id], map: "idx_recipe_ingredients_recipe")
  @@index([food_id], map: "idx_recipe_ingredients_food")
}

/// 推荐归因追踪表 — 记录每次推荐请求的完整上下文和评分快照，用于效果归因和策略优化
model recommendation_traces {
  /// 主键 UUID
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  user_id           String   @db.Uuid
  /// 餐次类型：breakfast/lunch/dinner/snack
  meal_type         String   @db.VarChar(20)
  /// 用户当前目标类型（如 fat_loss/muscle_gain/health）
  goal_type         String   @db.VarChar(30)
  /// 推荐渠道（如 home_cook/restaurant/delivery，默认 unknown）
  channel           String   @default("unknown") @db.VarChar(20)
  /// 所用策略 ID（外键 → strategy.id，null=使用全局默认策略）
  strategy_id       String?  @db.Uuid
  /// 所用策略版本号
  strategy_version  String?  @db.VarChar(50)
  /// 关联的 A/B 实验 ID
  experiment_id     String?  @db.Uuid
  /// 命中的实验分组标识
  group_id          String?  @db.VarChar(30)
  pipeline_snapshot Json?    /// 推荐管道完整快照：权重、过滤器、boost 参数等
  top_foods         Json?    /// 最终推荐的 top-N 食物列表（含评分明细）
  score_stats       Json?    /// 评分统计：min/max/avg/std 各维度
  food_pool_size    Int?     /// 候选池大小
  filters_applied   Json?    /// 应用的过滤器及过滤数量
  duration_ms       Int?     /// 推荐计算耗时（毫秒）
  /// 推荐请求时间
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id, created_at(sort: Desc)], map: "idx_rec_traces_user_created")
  @@index([strategy_id], map: "idx_rec_traces_strategy")
  @@index([experiment_id], map: "idx_rec_traces_experiment")
  @@index([channel], map: "idx_rec_traces_channel")
  @@index([created_at], map: "idx_rec_traces_created")
}

/// 菜谱多语言翻译表 — 存储菜谱的多语言名称、描述和步骤说明，每条记录对应一种语言
model recipe_translations {
  /// 主键 UUID
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的菜谱 ID（外键 → recipes.id）
  recipe_id    String   @db.Uuid
  /// 语言区域代码（如 zh-CN/en-US/ja-JP）
  locale       String   @db.VarChar(10)
  /// 该语言下的菜谱名称
  name         String   @db.VarChar(200)
  /// 该语言下的菜谱描述
  description  String?
  instructions Json?    /// 翻译后的步骤说明
  /// 创建时间
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  /// 最后更新时间
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  recipe recipes @relation(fields: [recipe_id], references: [id], onDelete: Cascade)

  @@unique([recipe_id, locale], map: "uq_recipe_translation_recipe_locale")
  @@index([locale], map: "idx_recipe_translations_locale")
}

