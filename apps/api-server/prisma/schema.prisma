/// 菜谱表 — 存储 AI 生成或人工录入的菜谱，包含营养信息、烹饪步骤及审核状态
model Recipes {
  /// 主键 UUID
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 菜谱名称
  name               String               @db.VarChar(200)
  /// 菜谱描述
  description        String?
  /// 菜系（如 chinese/japanese/western/korean）
  cuisine            String?              @db.VarChar(50)
  /// 制作难度：1=简单, 2=中等, 3=较难, 4=困难, 5=专业
  difficulty         Int                  @default(1) @db.SmallInt
  /// 备料时间，单位分钟
  prepTimeMinutes    Int?                 @map("prep_time_minutes")
  /// 烹饪时间，单位分钟
  cookTimeMinutes    Int?                 @map("cook_time_minutes")
  /// 份数（默认 1 人份）
  servings           Int                  @default(1) @db.SmallInt
  /// 标签列表（如 ["低脂","高蛋白","快手菜"]）
  tags               String[]
  /// 烹饪步骤（JSON 数组，每步含 step/description/image_url）
  instructions       Json?
  /// 菜谱封面图 URL
  imageUrl           String?              @map("image_url") @db.VarChar(500)
  /// 数据来源：ai_generated=AI 生成, user_submitted=用户提交, curated=人工精选
  source             String               @default("ai_generated") @db.VarChar(50)
  /// 每份热量，单位 kcal
  caloriesPerServing Decimal?             @map("calories_per_serving") @db.Decimal(8, 2)
  /// 每份蛋白质，单位 g
  proteinPerServing  Decimal?             @map("protein_per_serving") @db.Decimal(8, 2)
  /// 每份脂肪，单位 g
  fatPerServing      Decimal?             @map("fat_per_serving") @db.Decimal(8, 2)
  /// 每份碳水化合物，单位 g
  carbsPerServing    Decimal?             @map("carbs_per_serving") @db.Decimal(8, 2)
  /// 每份膳食纤维，单位 g
  fiberPerServing    Decimal?             @map("fiber_per_serving") @db.Decimal(8, 2)
  /// 综合质量评分 0.00-5.00（AI 评估的营养均衡度、做法完整性等）
  qualityScore       Decimal              @default(0) @map("quality_score") @db.Decimal(5, 2)
  /// 被推荐/引用次数（用于热度排序）
  usageCount         Int                  @default(0) @map("usage_count")
  /// 审核状态：pending=待审核, approved=已通过, rejected=已拒绝
  reviewStatus       String               @default("approved") @map("review_status") @db.VarChar(20)
  /// 提交人用户 ID（用户提交时填写）
  submittedBy        String?              @map("submitted_by") @db.Uuid
  /// 审核人管理员 ID
  reviewedBy         String?              @map("reviewed_by") @db.Uuid
  /// 审核时间
  reviewedAt         DateTime?            @map("reviewed_at") @db.Timestamptz(6)
  /// 审核备注（拒绝时填写原因）
  reviewNote         String?              @map("review_note")
  /// 是否上架（false=下架，不可推荐）
  isActive           Boolean              @default(true) @map("is_active")
  availableChannels  Json                 @default("[\"home_cook\"]") @map("available_channels") /// 可获取渠道: home_cook/restaurant/delivery/convenience
  /// 创建时间
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt          DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  recipeIngredients  RecipeIngredients[]
  recipeTranslations RecipeTranslations[]
  recipeRatings      RecipeRatings[]
  dailyPlanItems     DailyPlanItems[]

  @@index([cuisine], map: "idx_recipes_cuisine")
  @@index([difficulty], map: "idx_recipes_difficulty")
  @@index([reviewStatus], map: "idx_recipes_review_status")
  @@index([tags], map: "idx_recipes_tags", type: Gin)
  @@index([qualityScore(sort: Desc)], map: "idx_recipes_quality")
  @@map("recipes")
}

/// 菜谱食材明细表 — 存储每道菜谱所需的食材列表及用量
model RecipeIngredients {
  /// 主键 UUID
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的菜谱 ID（外键 → recipes.id）
  recipeId       String   @map("recipe_id") @db.Uuid
  /// 对应食物库中的食物 ID（可选，无精确匹配时为 null）
  foodId         String?  @map("food_id") @db.Uuid
  /// 食材名称（展示用，如"鸡胸肉"）
  ingredientName String   @map("ingredient_name") @db.VarChar(100)
  /// 用量数值（如 200）
  amount         Decimal? @db.Decimal(8, 2)
  /// 用量单位（如 g/ml/个/勺）
  unit           String?  @db.VarChar(20)
  /// 是否为可选食材（false=必选，true=可省略）
  isOptional     Boolean  @default(false) @map("is_optional")
  /// 显示排序（值越小越靠前）
  sortOrder      Int      @default(0) @map("sort_order") @db.SmallInt

  recipe Recipes @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  food   Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([recipeId], map: "idx_recipe_ingredients_recipe")
  @@index([foodId], map: "idx_recipe_ingredients_food")
  @@map("recipe_ingredients")
}

/// 推荐归因追踪表 — 记录每次推荐请求的完整上下文和评分快照，用于效果归因和策略优化
model RecommendationTraces {
  /// 主键 UUID
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的用户 ID
  userId           String   @map("user_id") @db.Uuid
  /// 餐次类型：breakfast/lunch/dinner/snack
  mealType         String   @map("meal_type") @db.VarChar(20)
  /// 用户当前目标类型（如 fat_loss/muscle_gain/health）
  goalType         String   @map("goal_type") @db.VarChar(30)
  /// 推荐渠道（如 home_cook/restaurant/delivery，默认 unknown）
  channel          String   @default("unknown") @db.VarChar(20)
  /// 所用策略 ID（外键 → strategy.id，null=使用全局默认策略）
  strategyId       String?  @map("strategy_id") @db.Uuid
  /// 所用策略版本号
  strategyVersion  String?  @map("strategy_version") @db.VarChar(50)
  /// 关联的 A/B 实验 ID
  experimentId     String?  @map("experiment_id") @db.Uuid
  /// 命中的实验分组标识
  groupId          String?  @map("group_id") @db.VarChar(30)
  pipelineSnapshot Json?    @map("pipeline_snapshot") /// 推荐管道完整快照：权重、过滤器、boost 参数等
  topFoods         Json?    @map("top_foods") /// 最终推荐的 top-N 食物列表（含评分明细）
  scoreStats       Json?    @map("score_stats") /// 评分统计：min/max/avg/std 各维度
  foodPoolSize     Int?     @map("food_pool_size") /// 候选池大小
  filtersApplied   Json?    @map("filters_applied") /// 应用的过滤器及过滤数量
  durationMs       Int?     @map("duration_ms") /// 推荐计算耗时（毫秒）
  /// V7.9: 管道全链路追踪数据（PipelineTrace JSON）
  traceData        Json?    @map("trace_data")
  /// V7.9: 策略名称（冗余存储，便于查询）
  strategyName     String?  @map("strategy_name") @db.VarChar(60)
  /// V7.9: 场景名称（如 eating_out/home_cook 等）
  sceneName        String?  @map("scene_name") @db.VarChar(40)
  /// V7.9: 现实性级别（off/relaxed/normal/strict）
  realismLevel     String?  @map("realism_level") @db.VarChar(20)
  /// V7.9: 候选数流转路径（如 "384→152→30→5"）
  candidateFlow    String?  @map("candidate_flow") @db.VarChar(100)
  /// V7.9: 管道总耗时（毫秒）
  totalDurationMs  Int?     @map("total_duration_ms")
  /// V7.9: 是否命中缓存
  cacheHit         Boolean? @map("cache_hit")
  /// V7.9: 降级列表（JSON array of stage names）
  degradations     Json?    @map("degradations")
  /// 推荐请求时间
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt(sort: Desc)], map: "idx_rec_traces_user_created")
  @@index([strategyId], map: "idx_rec_traces_strategy")
  @@index([experimentId], map: "idx_rec_traces_experiment")
  @@index([channel], map: "idx_rec_traces_channel")
  @@index([createdAt], map: "idx_rec_traces_created")
  @@index([sceneName], map: "idx_rec_traces_scene")
  @@map("recommendation_traces")
}

