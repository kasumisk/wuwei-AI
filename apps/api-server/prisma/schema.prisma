/// 死信队列 — BullMQ 永久失败任务存储，用于审计和重放
model dead_letter_jobs {
  /// 主键 UUID
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 所属队列名称（如 recommendation/notification）
  queue_name    String    @db.VarChar(50)
  /// BullMQ 任务 ID
  job_id        String    @db.VarChar(100)
  /// 任务原始数据（JSON）
  job_data      Json
  /// 最终失败的错误信息
  error_message String    @db.Text
  /// 已重试次数
  attempts_made Int       @default(0)
  status        String    @default("pending") @db.VarChar(20) /// pending / retried / discarded
  /// 任务失败时间
  failed_at     DateTime  @default(now()) @db.Timestamptz(6)
  /// 最后一次手动重试时间
  retried_at    DateTime? @db.Timestamptz(6)
  /// 记录创建时间
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([queue_name, status], map: "idx_dlj_queue_status")
  @@index([failed_at], map: "idx_dlj_failed_at")
}

/// 每日计划食物明细 — daily_plans JSON 规范化，每行代表一个餐次中的一个食物/菜谱项
model daily_plan_items {
  /// 主键 UUID
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 关联的每日计划 ID（外键 → daily_plans.id）
  daily_plan_id String  @db.Uuid
  meal_type     String  @db.VarChar(20) /// morning / lunch / dinner / snack
  role          String  @db.VarChar(20) /// carb / protein / veggie / side / snack
  /// 关联的食物 ID（food_id 和 recipe_id 二选一）
  food_id       String? @db.Uuid
  /// 关联的菜谱 ID（food_id 和 recipe_id 二选一）
  recipe_id     String? @db.Uuid
  /// 食物/菜谱名称（冗余存储，方便展示）
  food_name     String  @db.VarChar(200)
  /// 热量，单位 kcal
  calories      Float?
  /// 蛋白质，单位 g
  protein       Float?
  /// 脂肪，单位 g
  fat           Float?
  /// 碳水化合物，单位 g
  carbs         Float?
  /// 推荐分数 0-1（推荐引擎给出的综合评分）
  score         Float?
  /// 餐次内排序（值越小越靠前）
  sort_order    Int     @default(0)

  daily_plan daily_plans @relation(fields: [daily_plan_id], references: [id], onDelete: Cascade)
  food       foods?      @relation(fields: [food_id], references: [id])
  recipe     recipes?    @relation(fields: [recipe_id], references: [id])

  @@index([daily_plan_id, meal_type], map: "idx_dpi_plan_meal")
  @@index([food_id], map: "idx_dpi_food")
  @@index([recipe_id], map: "idx_dpi_recipe")
}

/// 菜谱用户评分表 — 存储用户对菜谱的评分和评论，每用户每菜谱一条
model recipe_ratings {
  /// 主键 UUID
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
