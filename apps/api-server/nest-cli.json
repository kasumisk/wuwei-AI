{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "monorepo": false,
  "root": "./",
  "entryFile": "./main",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      { "include": "**/i18n/*.json", "outDir": "dist", "watchAssets": true },
      { "include": "common/i18n/*.json", "outDir": "dist", "watchAssets": true }
    ]
  }
}
